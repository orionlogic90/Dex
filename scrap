                    'Accept': 'application/json'
                },
                credentials: 'include',
                body: JSON.stringify(payload)
            });
            
            if (response.ok) {
                addLog('[CHAT] Sent: ' + message, '#4ade80', '[💬]');
                return true;
            } else {
                addLog('[CHAT] Failed: ' + response.status, '#ff6b6b', '[❌]');
                return false;
            }
            
        } catch(e) {
            addLog('[CHAT] Error: ' + e.message, '#ff6b6b', '[❌]');
