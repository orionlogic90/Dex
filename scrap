    // ============================================================
    // PLACE BET WITH RETRY
    // ============================================================
    async function placeBetWithRetry(betAmount, chance, maxRetries) {
        maxRetries = maxRetries || 3;
        
        for (var attempt = 1; attempt <= maxRetries; attempt++) {
            try {
                var result = await placeBet(betAmount, chance);
                if (result.success) {
                    return result;
                }
                
                if (attempt < maxRetries) {
                    var delay = randomDelay(1000, 3000);
                    addLog('[RETRY] Bet failed (attempt ' + attempt + '/' + maxRetries + '), retrying in ' + delay + 'ms...', '#ff922b', '[🔄]');
                    await sleep(delay);
                } else {
                    addLog('[RETRY] Bet failed after ' + maxRetries + ' attempts: ' + result.error, '#ff6b6b', '[❌]');
                    return result;
                }
            } catch(e) {
                if (attempt < maxRetries) {
                    var delay = randomDelay(1000, 3000);
                    addLog('[RETRY] Network error (attempt ' + attempt + '/' + maxRetries + '), retrying in ' + delay + 'ms...', '#ff922b', '[🔄]');
                    await sleep(delay);
                } else {
                    addLog('[RETRY] Network error after ' + maxRetries + ' attempts: ' + e.message, '#ff6b6b', '[❌]');
                    return { success: false, error: e.message };
                }
            }
        }
        return { success: false, error: 'Max retries exceeded' };
    }

    // ============================================================
    // WAGER BOT CORE
    // ============================================================
    function getRealBalance() {
        try {
            var selectors = [
                '[class*="balance"]', '[class*="Balance"]',
                '[data-testid="balance"]', '.balance-amount',
                '.user-balance', '.wallet-balance',
                '[class*="wallet"] [class*="amount"]',
                '[data-testid="wallet-balance"]'
            ];
            for (var i = 0; i < selectors.length; i++) {
                var elements = document.querySelectorAll(selectors[i]);
                for (var j = 0; j < elements.length; j++) {
                    var text = elements[j].textContent.trim();
                    var match = text.match(/(\d+\.?\d*)/);
                    if (match) {
                        var num = parseFloat(match[1]);
                        if (num > 0) return num;
                    }
                }
            }
            return null;
        } catch(e) {
            return null;
        }
    }

    async function placeBet(betAmount, chance) {
        var cryptoCurrency = getCurrency();
        var rollMode = 'Under';
        var targetNumber = Math.floor((chance / 100) * 10000);

        var query = 'mutation PlaceDiceBet($input: DiceBetInput!) { placeDiceBet(input: $input) { roundId activityId betAmount targetNumber targetNumberLower targetNumberUpper rollMode rolledNumber multiplier winAmount isWin profit timestamp __typename } }';

        var variables = {
            input: {
                betAmount: String(betAmount),
                cryptoCurrency: cryptoCurrency,
                nonce: generateUUID(),
                rollMode: rollMode,
                targetNumber: targetNumber
            }
        };

        var payload = {
            operationName: "PlaceDiceBet",
            query: query,
            variables: variables
        };

        try {
            var response = await fetch('https://api.dicey.com/graphql', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'Accept': 'application/graphql-response+json, application/graphql+json, application/json',
                    'Origin': 'https://dicey.com'
                },
                credentials: 'include',
                body: JSON.stringify(payload)
            });

            if (!response.ok) {
                throw new Error('HTTP ' + response.status);
            }

            var data = await response.json();
            if (data.errors) {
                throw new Error(data.errors[0].message);
            }
            return { success: true, data: data.data.placeDiceBet };
        } catch (error) {
            return { success: false, error: error.message };
        }
    }

