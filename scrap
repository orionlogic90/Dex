    async function refreshStreamToken() {
        try {
            const response = await fetch('https://api.dicey.com/graphql', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                credentials: 'include',
                body: JSON.stringify({
                    operationName: 'StreamAuthToken',
                    query: `
                        query StreamAuthToken {
                            streamAuthToken {
                                token
                                apiKey
                                userId
                            }
                        }
                    `
                })
            });
            const data = await response.json();
            const result = {
                token: data?.data?.streamAuthToken?.token || null,
                apiKey: data?.data?.streamAuthToken?.apiKey || null,
                userId: data?.data?.streamAuthToken?.userId || null
            };
            
            if (result.token) {
                cachedStreamToken = result.token;
                localStorage.setItem('dicey_stream_token', result.token);
            }
            if (result.apiKey) {
                localStorage.setItem('dicey_stream_apikey', result.apiKey);
            }
            if (result.userId) {
                localStorage.setItem('dicey_stream_userid', result.userId);
            }
            
            return result;
        } catch(e) {
            return null;
        }
    }

    async function getChatConnectionId() {
        if (chatConnectionId) {
            return chatConnectionId;
        }
        
        const stream = await refreshStreamToken();
        if (!stream || !stream.token) return null;
        
        try {
            const eventUrl = 'https://chat.stream-io-api.com/channels/messaging/lobby-en/event' +
                '?user_id=' + stream.userId +
                '&api_key=' + (stream.apiKey || 'gszqy9y9nr3e3');
            
            const response = await fetch(eventUrl, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'Authorization': stream.token,
                    'stream-auth-type': 'jwt',
                    'Origin': 'https://dicey.com'
                },
                credentials: 'include',
                body: JSON.stringify({ event: { type: 'typing.start' } })
            });
            
            const responseUrl = response.url;
            if (responseUrl) {
                const urlObj = new URL(responseUrl);
                const connId = urlObj.searchParams.get('connection_id');
                if (connId) {
                    chatConnectionId = connId;
                    localStorage.setItem('dicey_chat_conn_id', connId);
                    return connId;
                }
            }
            
            return null;
        } catch(e) {
            return null;
        }
    }

    async function sendChatToDicey(message) {
        try {
            const stream = await refreshStreamToken();
            if (!stream || !stream.token) {
                addLog('[CHAT] No stream token', '#ff6b6b', '[❌]');
                return false;
            }
            
            const connectionId = await getChatConnectionId();
            if (!connectionId) {
