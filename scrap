    // ============================================================
    // FISHING MOMENT
    // ============================================================
    let fishingDone = false;
    let fishingTotalBets = 0;
    const MAX_FISHING_BETS = 15;

    function updateFishingUI(done, status) {
        const el = document.getElementById('dicey-fishing-status');
        const amountEl = document.getElementById('dicey-fishing-amount');
        if (el) {
            el.textContent = 'Fishing: ' + status;
            el.style.color = done ? '#4ade80' : '#ff922b';
        }
        if (amountEl) {
            const currency = getCurrency();
            const price = getCoinPrice(currency);
            const betValue = 0.03 / price;
            amountEl.textContent = betValue.toFixed(4) + ' ' + currency;
        }
    }

    function getConvertedFishingAmount() {
        const currency = getCurrency();
        const price = getCoinPrice(currency);
        return 0.03 / price;
    }

    async function doFishingMoment() {
        if (fishingDone) {
            updateFishingUI(true, 'Done (' + fishingTotalBets + ' bets)');
            return true;
        }

        const balance = await fetchBalance();
        if (balance <= 0) {
            addLog('Fishing: Insufficient balance', '#f87171', '[F]');
            return false;
        }

        const currency = getCurrency();
        const baseBet = getConvertedFishingAmount();
        const maxPercent = 3;
        const maxAllowed = balance * (maxPercent / 100);
        let betAmount = Math.min(baseBet, maxAllowed);

        betAmount = betAmount * randomFloat(0.7, 1.3);
        betAmount = Math.min(betAmount, maxAllowed);
        betAmount = Math.max(betAmount, 0.0001);

        const chance = randomFloat(92, 98);

        fishingTotalBets++;
        const attemptLabel = fishingTotalBets;

        addLog('Fishing #' + attemptLabel + ': ' + betAmount.toFixed(4) + ' ' + currency + ' @ ' + chance.toFixed(1) + '%', '#ff922b', '[F]');
        updateFishingUI(false, 'Bet #' + attemptLabel);

        await sleep(randomDelay(500, 2000));

        try {
            const result = await placeBetWithRetry(betAmount, chance);

            if (result.success) {
                const data = result.data;
                const profit = parseFloat(data.profit) || 0;
                const isWin = data.isWin;

                addLog('Fishing #' + attemptLabel + ' ' + (isWin ? 'WIN' : 'LOSS') + ' | Profit: ' + profit.toFixed(4), isWin ? '#4ade80' : '#ff6b81', '[F]');

                const shouldContinue = fishingTotalBets < MAX_FISHING_BETS && Math.random() < 0.7;

                if (!shouldContinue || fishingTotalBets >= MAX_FISHING_BETS) {
                    fishingDone = true;
                    updateFishingUI(true, 'Done (' + fishingTotalBets + ' bets)');
                    addLog('Fishing completed: ' + fishingTotalBets + ' bets placed', '#4ade80', '[F]');
                    return true;
                }

                const delay = getRandomFishingDelay();
                await sleep(delay);

                return doFishingMoment();

            } else {
                addLog('Fishing #' + attemptLabel + ' failed: ' + result.error, '#f87171', '[F]');

                await sleep(randomDelay(2000, 5000));

                if (fishingTotalBets < MAX_FISHING_BETS && Math.random() < 0.5) {
                    return doFishingMoment();
                } else {
                    fishingDone = true;
                    updateFishingUI(true, 'Done (' + fishingTotalBets + ' bets)');
                    return true;
                }
            }
        } catch(e) {
            addLog('Fishing error: ' + e.message, '#f87171', '[F]');
            await sleep(randomDelay(3000, 6000));

            if (fishingTotalBets < MAX_FISHING_BETS) {
                return doFishingMoment();
            } else {
                fishingDone = true;
                updateFishingUI(true, 'Done (' + fishingTotalBets + ' bets)');
                return true;
            }
        }
    }

