    // ============================================================
    // UPDATE RAIN TIMER UI + CHAT EMOJI ALERT
    // ============================================================
    function updateRainTimer(rainData) {
        const nextEl = document.getElementById('dicey-rain-next');
        const endsEl = document.getElementById('dicey-rain-ends');
        const amountEl = document.getElementById('dicey-rain-amount');
        const participantsEl = document.getElementById('dicey-rain-participants');

        if (!rainData) {
            if (nextEl) nextEl.textContent = 'Next: --';
            if (endsEl) endsEl.textContent = 'Ends: --';
            if (amountEl) amountEl.textContent = 'Amount: --';
            if (participantsEl) participantsEl.textContent = 'Players: --';
            return;
        }

        const now = new Date();
        const startsAt = new Date(rainData.startsAt);
        const settlesAt = new Date(rainData.settlesAt);
        const status = rainData.status;

        if (amountEl) amountEl.textContent = 'Amount: $' + parseFloat(rainData.totalUsdAmount || 0).toFixed(2);
        if (participantsEl) participantsEl.textContent = 'Players: ' + (rainData.participantCount || 0);

        if (status === 'Settled' || now > settlesAt) {
            if (nextEl) nextEl.textContent = 'Next: Finished';
            if (endsEl) endsEl.textContent = 'Ends: --';
            chatEmojiSent = false;
            return;
        }

        if (now >= startsAt && now <= settlesAt) {
            const timeLeft = settlesAt.getTime() - now.getTime();
            const mins = String(Math.floor(timeLeft / 60000)).padStart(2, '0');
            const secs = String(Math.floor((timeLeft % 60000) / 1000)).padStart(2, '0');
            if (nextEl) nextEl.textContent = 'Next: Active';
            if (endsEl) endsEl.textContent = 'Ends: ' + mins + ':' + secs;
            
            // CHAT EMOJI ALERT - 1x per rain, random 1-10 detik sebelum settle
            if (!chatEmojiSent && timeLeft <= 10000 && timeLeft > 0) {
                const randomTrigger = Math.floor(Math.random() * 9000) + 1000;
                if (timeLeft <= randomTrigger) {
                    chatEmojiSent = true;
                    const secondsLeft = Math.ceil(timeLeft / 1000);
                    addLog('🌧️ RAIN SETTLING IN ' + secondsLeft + 's! ($' + parseFloat(rainData.totalUsdAmount || 0).toFixed(2) + ')', '#ff922b', '[⏰]');
                    
                    setTimeout(async () => {
                        await sendRandomChatEmoji();
                    }, randomDelay(100, 500));
                }
            }
        } else if (now < startsAt) {
            const timeUntil = startsAt.getTime() - now.getTime();
            const mins = String(Math.floor(timeUntil / 60000)).padStart(2, '0');
            const secs = String(Math.floor((timeUntil % 60000) / 1000)).padStart(2, '0');
            if (nextEl) nextEl.textContent = 'Next: ' + mins + ':' + secs;
            if (endsEl) endsEl.textContent = 'Starts: ' + startsAt.toLocaleTimeString();
            
            chatEmojiSent = false;
        }
    }

