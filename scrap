    async function claimRakeback(currency) {
        try {
            const response = await fetch('https://api.dicey.com/graphql', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                credentials: 'include',
                body: JSON.stringify({
                    operationName: 'ClaimRakeback',
                    query: `
                        mutation ClaimRakeback($currency: PlatformCurrency!) {
                            claimRakeback(currency: $currency) {
                                amount {
                                    currencyCode
                                    smallestUnits
                                }
                            }
                        }
                    `,
                    variables: { currency: currency }
                })
            });
            const data = await response.json();
            const amount = data?.data?.claimRakeback?.amount;
            if (amount) {
                const value = amount.smallestUnits / 1000000;
                addLog('[CLAIM] Rakeback: ' + value.toFixed(4) + ' ' + amount.currencyCode, '#4ade80', '[💰]');
                return { success: true, amount: value };
            }
            return { success: false };
        } catch(e) {
            addLog('[CLAIM] Rakeback error: ' + e.message, '#ff6b6b', '[❌]');
            return { success: false };
        }
    }

    async function claimFreespins(issueId) {
        try {
            const response = await fetch('https://api.dicey.com/graphql', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                credentials: 'include',
                body: JSON.stringify({
                    operationName: 'ClaimFreespins',
                    query: `
                        mutation ClaimFreespins($issueId: ID!) {
                            claimFreespins(issueId: $issueId) {
