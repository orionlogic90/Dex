    // ============================================================
    // JOIN RAIN
    // ============================================================
    async function joinRainDirect(potId) {
        try {
            const response = await fetch('https://api.dicey.com/graphql', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                credentials: 'include',
                body: JSON.stringify({
                    operationName: 'JoinRain',
                    query: `
                        mutation JoinRain($potId: ID!) {
                            joinRain(potId: $potId) {
                                joined alreadyJoined ineligibleReason
                            }
                        }
                    `,
                    variables: { potId }
                })
            });
            return await response.json();
        } catch(e) {
            return { error: e.message };
        }
    }

    // ============================================================
    // HANDLE RAIN EVENT
    // ============================================================
    function handleRainEvent(rainData) {
        const potId = rainData.id;

        if (rainState.joinedRains.has(potId)) {
            return;
        }

        addLog('Joining rain: $' + rainData.totalUsdAmount, '#ff922b', '[R]');

        setTimeout(() => {
            joinRainDirect(potId).then(result => {
                if (result?.data?.joinRain?.joined === true) {
                    rainState.successCount++;
                    rainState.joinedRains.add(potId);
                    addLog('Joined rain!', '#4ade80', '[R]');
                    updateRainUI();
                    return;
                }

                const reason = result?.data?.joinRain?.ineligibleReason || 'Unknown';
                rainState.failCount++;
                addLog('Failed: ' + reason, '#f87171', '[R]');
                updateRainUI();

                const wagerReasons = [
                    'InsufficientWager',
                    'WagerTooLow',
                    'WagerRequirementNotMet',
                    'InsufficientWagered',
                    'WagerRequirement'
                ];

                const isWagerIssue = wagerReasons.some(r =>
                    reason === r || reason.toLowerCase().includes('wager') || reason.toLowerCase().includes('wagered')
                );

                if (isWagerIssue) {
                    addLog('Insufficient wager detected! Auto wager started...', '#ff922b', '[W]');

                    const wasRunning = rainState.isRunning;

                    if (wasRunning) {
                        rainState.isRunning = false;
                        if (rainState.scheduledTimeout) {
                            clearTimeout(rainState.scheduledTimeout);
                            rainState.scheduledTimeout = null;
                        }
                        stopRainTimer();
                        stopChatRefreshLoop();
                        addLog('Rain catcher paused for wager', '#ff922b', '[W]');
                    }

                    sendTelegramNotification('AUTO_WAGER_RAIN');

                    doAutoWagerToTarget().then(success => {
                        if (success) {
                            addLog('Wager target reached! Resuming rain catcher...', '#4ade80', '[W]');
                            if (wasRunning) {
                                rainState.joinedRains = new Set();
                                startRainBot();
                                setTimeout(() => {
                                    addLog('Retrying join rain...', '#60a5fa', '[R]');
                                    handleRainEvent(rainData);
                                }, randomDelay(2000, 5000));
                            }
                        } else {
                            addLog('Failed to reach wager target', '#f87171', '[W]');
                            if (wasRunning) {
                                startRainBot();
                            }
                        }
                    });
                }
            });
        }, randomDelay(500, 2000));
    }

    // ============================================================
    // AUTO WAGER TO TARGET (untuk rain)
    // ============================================================
    async function doAutoWagerToTarget() {
        const currency = getCurrency();
        const betAmount = parseFloat($('dicey-layer1-bet')?.value || 0.01);
        const chance = parseFloat($('dicey-layer1-chance')?.value || 98);
        const maxAttempts = 300;

        let currentWager = wagerState.wagered || 0;
        let attempts = 0;
        let successCount = 0;

        isAutoWagerForRain = true;
        addLog('Auto wager started - Target: ' + WAGER_TARGET + ' ' + currency, '#60a5fa', '[W]');

        while (currentWager < WAGER_TARGET && attempts < maxAttempts) {
            attempts++;

            addLog('Wager ' + attempts + ': ' + betAmount + ' ' + currency + ' @ ' + chance + '%', '#60a5fa', '[W]');

            const result = await placeBetWithRetry(betAmount, chance);

            if (result.success) {
                successCount++;
                currentWager += betAmount;
                wagerState.wagered += betAmount;

                if (attempts % 5 === 0 || currentWager >= WAGER_TARGET) {
                    addLog('Wager progress: ' + currentWager.toFixed(4) + '/' + WAGER_TARGET + ' ' + currency + ' (' + (currentWager/WAGER_TARGET*100).toFixed(1) + '%)', '#ffd700', '[P]');
                }
            } else {
                addLog('Wager ' + attempts + ' failed: ' + result.error, '#ff922b', '[X]');
            }

            await sleep(randomDelay(300, 700));
        }

        isAutoWagerForRain = false;
        addLog('Auto wager completed: ' + successCount + ' success, ' + (attempts - successCount) + ' failed', '#60a5fa', '[W]');
        addLog('Total wagered: ' + currentWager.toFixed(4) + ' ' + currency, '#60a5fa', '[W]');

        updateWagerTarget();
        updateWagerUI();

        return currentWager >= WAGER_TARGET;
    }

    // ============================================================
    // CHECK RAIN PAYOUT + FORCE RESTART
    // ============================================================
    async function checkRainPayoutAndRestart() {
        try {
            const response = await fetch('https://api.dicey.com/graphql', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                credentials: 'include',
                body: JSON.stringify({
                    operationName: 'UserActivities',
                    query: `
                        query UserActivities($filters: UserActivityFilters, $first: Int) {
                            userActivities(filters: $filters, first: $first) {
                                edges {
                                    node {
                                        id
                                        type
                                        status
                                        time
                                        usdAmount
                                        amount {
                                            smallestUnits
                                            currencyCode
                                        }
                                    }
                                }
                            }
                        }
                    `,
                    variables: {
                        filters: { category: "REWARDS" },
                        first: 5
                    }
                })
            });

            const data = await response.json();
            const activities = data?.data?.userActivities?.edges || [];

            const now = Date.now();
            const fiveMinutesAgo = now - (5 * 60 * 1000);

            let foundPayout = false;
            let payoutAmount = 0;
            let payoutTime = null;

            for (let edge of activities) {
                const node = edge.node;
                if (node.type === 'RAIN_PAYOUT' && node.status === 'FINALIZED') {
                    const payoutTimeNode = new Date(node.time).getTime();
                    if (payoutTimeNode > fiveMinutesAgo) {
                        foundPayout = true;
                        payoutAmount = parseFloat(node.usdAmount);
                        payoutTime = node.time;
                        break;
                    }
                }
            }

            if (foundPayout) {
                addLog('YOU WON! +' + payoutAmount.toFixed(2) + ' USD', '#ffd700', '[WIN]');
                updatePayoutUI({ win: true, usdAmount: payoutAmount, time: payoutTime });
                sendTelegramNotification('RAIN_WIN', '🎉 You won $' + payoutAmount.toFixed(2) + ' USD from rain!');
            } else {
                addLog('No payout found (lost or didn\'t join)', '#888', '[INFO]');
                updatePayoutUI({ win: false });
            }

            addLog('Stopping bot for fresh start...', '#60a5fa', '[R]');

            if (wagerState.isRunning) {
                stopWagerBot();
                wagerState.isRunning = false;
                wagerState.isPaused = false;
            }

            if (rainState.isRunning) {
                rainState.isRunning = false;
                if (rainState.scheduledTimeout) {
                    clearTimeout(rainState.scheduledTimeout);
                    rainState.scheduledTimeout = null;
                }
                stopRainTimer();
                stopChatRefreshLoop();
                rainState.joinedRains = new Set();
                rainState.successCount = 0;
                rainState.failCount = 0;
                fishingDone = false;
                fishingTotalBets = 0;
                updateFishingUI(false, 'Pending');
                updateRainUI();
            }

            await sleep(randomDelay(1500, 4000));

            if (prevWagerRunning) {
                addLog('Restarting wager...', '#4ade80', '[R]');
                startWagerBot();
            }
            if (prevRainRunning) {
                addLog('Restarting rain...', '#4ade80', '[R]');
                rainState.isRunning = false;
                rainState.joinedRains = new Set();
                rainState.successCount = 0;
                rainState.failCount = 0;
                fishingDone = false;
                fishingTotalBets = 0;
                updateFishingUI(false, 'Pending');
                startRainBot();
            }

            addLog('Bot force restarted!', '#4ade80', '[OK]');

            return { win: foundPayout, amount: payoutAmount };

        } catch(e) {
            addLog('Payout check error: ' + e.message, '#f87171', '[ERR]');

            addLog('Restarting bot (error recovery)...', '#60a5fa', '[R]');
            if (wagerState.isRunning) stopWagerBot();
            if (rainState.isRunning) {
                rainState.isRunning = false;
                stopRainTimer();
                stopChatRefreshLoop();
                rainState.joinedRains = new Set();
                rainState.successCount = 0;
                rainState.failCount = 0;
                updateRainUI();
            }
            await sleep(randomDelay(2000, 5000));
            if (prevWagerRunning) startWagerBot();
            if (prevRainRunning) startRainBot();

            return { win: false, error: e.message };
        }
    }

    // ============================================================
    // RAIN CYCLE
    // ============================================================
    function runRainCycle() {
        if (!rainState.isRunning) return;

        addLog('Checking rain schedule...', '#60a5fa', '[R]');

        if (!window.location.href.includes('/chat')) {
            addLog('Navigating to /chat...', '#60a5fa', '[R]');
            window.location.href = 'https://dicey.com/chat';
            setTimeout(() => {
                if (rainState.isRunning) {
                    runRainCycle();
                }
            }, randomDelay(2000, 4000));
            return;
        }

        if (!fishingDone) {
            const betValue = getConvertedFishingAmount();
            addLog('Fishing required: ~' + betValue.toFixed(4) + ' ' + getCurrency() + ' @ random % (0.03 USD)', '#ff922b', '[F]');
            doFishingMoment().then(() => {
                if (rainState.isRunning) {
                    executeRainCycle();
                }
            });
            return;
        }

        executeRainCycle();
    }

    function executeRainCycle() {
        if (!rainState.isRunning) return;

        startRainTimer();
        startChatRefreshLoop();
        startHumanBehavior();

        setTimeout(() => {
            fetchRainSchedule().then(rainData => {
                if (rainData) {
                    updateRainTimer(rainData);

                    const now = new Date();
                    const startsAt = new Date(rainData.startsAt);
                    const settlesAt = new Date(rainData.settlesAt);
                    const status = rainData.status;

                    if (status === 'Settled' || now > settlesAt) {
                        addLog('Rain settled! Checking payout...', '#888', '[R]');
                        checkRainPayoutAndRestart();
                        setTimeout(() => {
                            if (rainState.isRunning) {
                                runRainCycle();
                            }
                        }, randomDelay(4 * 60 * 1000, 6 * 60 * 1000));
                        return;
                    }

                    if (now >= startsAt && now <= settlesAt) {
                        addLog('Rain is active! $' + rainData.totalUsdAmount, '#ff922b', '[R]');
                        handleRainEvent(rainData);

                        const timeToSettle = settlesAt.getTime() - now.getTime();

                        setTimeout(() => {
                            addLog('Settle time! Checking payout...', '#ffd700', '[R]');
                            checkRainPayoutAndRestart();
                            setTimeout(() => {
                                if (rainState.isRunning) {
                                    runRainCycle();
                                }
                            }, randomDelay(4 * 60 * 1000, 6 * 60 * 1000));
                        }, timeToSettle + randomDelay(3000, 8000));
                        return;
                    }

                    if (now < startsAt) {
                        const timeUntilStart = startsAt.getTime() - now.getTime();
                        const minutesUntilStart = Math.floor(timeUntilStart / 60000);
                        addLog('Rain starts in ' + minutesUntilStart + ' minutes (at ' + startsAt.toLocaleTimeString() + ')', '#60a5fa', '[R]');

                        chatEmojiSent = false;

                        setTimeout(() => {
                            if (rainState.isRunning) {
                                runRainCycle();
                            }
                        }, timeUntilStart + randomDelay(1000, 5000));
                        return;
                    }

                } else {
                    addLog('No rain scheduled, checking again in 5 minutes...', '#888', '[R]');
                    setTimeout(() => {
                        if (rainState.isRunning) {
                            runRainCycle();
                        }
                    }, randomDelay(4 * 60 * 1000, 6 * 60 * 1000));
                }
            });
        }, randomDelay(500, 2000));
    }

    // ============================================================
    // RAIN START/STOP
    // ============================================================
    function startRainBot() {
        if (!isLicensed) {
            addLog('[!] License required for rain catcher', '#f87171', '[!]');
            return;
        }

        const currentWager = wagerState.wagered || 0;

        if (currentWager < WAGER_TARGET) {
            addLog('[RAIN] Insufficient wager: ' + currentWager.toFixed(4) + ' / ' + WAGER_TARGET + ' ' + getCurrency(), '#ff922b', '[R]');

            if (rainState.isRunning) {
                rainState.isRunning = false;
                if (rainState.scheduledTimeout) {
                    clearTimeout(rainState.scheduledTimeout);
                    rainState.scheduledTimeout = null;
                }
                stopRainTimer();
                stopChatRefreshLoop();
                stopHumanBehavior();
                rainState.joinedRains = new Set();
                rainState.successCount = 0;
                rainState.failCount = 0;
                fishingDone = false;
                fishingTotalBets = 0;
                updateFishingUI(false, 'Pending');
                updateRainUI();
            }

            addLog('[RAIN] Auto wager started...', '#60a5fa', '[W]');

            sendTelegramNotification('AUTO_WAGER_RAIN');

            if (!wagerState.isRunning) {
                startWagerBot();
            }

            const checkInterval = setInterval(() => {
                const wagerNow = wagerState.wagered || 0;
                addLog('[RAIN] Waiting for wager: ' + wagerNow.toFixed(4) + ' / ' + WAGER_TARGET + ' ' + getCurrency(), '#60a5fa', '[R]');

                if (wagerNow >= WAGER_TARGET) {
                    clearInterval(checkInterval);
                    addLog('[RAIN] Wager target reached! Starting rain...', '#4ade80', '[R]');

                    if (wagerState.isRunning) {
                        stopWagerBot();
                    }

                    rainState.isRunning = true;
                    rainState.joinedRains = new Set();
                    rainState.successCount = 0;
                    rainState.failCount = 0;
                    fishingDone = false;
                    fishingTotalBets = 0;
                    updateFishingUI(false, 'Pending');
                    updateRainUI();
                    prevRainRunning = true;
                    chatEmojiSent = false;

                    addLog('Rain catcher started (API Loop + Human Behavior)', '#4ade80', '[R]');
                    const betValue = getConvertedFishingAmount();
                    addLog('Fishing: ~' + betValue.toFixed(4) + ' ' + getCurrency() + ' @ random % (0.03 USD base)', '#ff922b', '[F]');

                    sendTelegramNotification('RAIN_START');

                    runRainCycle();
                }
            }, 5000);

            return;
        }

        if (rainState.isRunning) {
            addLog('Rain catcher still running, forcing stop...', '#ff922b', '[R]');
            rainState.isRunning = false;
            if (rainState.scheduledTimeout) {
                clearTimeout(rainState.scheduledTimeout);
                rainState.scheduledTimeout = null;
            }
            stopRainTimer();
            stopChatRefreshLoop();
            stopHumanBehavior();
            rainState.joinedRains = new Set();
            rainState.successCount = 0;
            rainState.failCount = 0;
            fishingDone = false;
            fishingTotalBets = 0;
            updateFishingUI(false, 'Pending');
            updateRainUI();
            sleep(randomDelay(500, 1500));
        }

        fishingDone = false;
        fishingTotalBets = 0;
        updateFishingUI(false, 'Pending');

        rainState.isRunning = true;
        rainState.joinedRains = new Set();
        rainState.successCount = 0;
        rainState.failCount = 0;
        updateRainUI();
        chatEmojiSent = false;

        prevRainRunning = true;
        addLog('Rain catcher started (API Loop + Human Behavior)', '#4ade80', '[R]');
        const betValue = getConvertedFishingAmount();
        addLog('Fishing: ~' + betValue.toFixed(4) + ' ' + getCurrency() + ' @ random % (0.03 USD base)', '#ff922b', '[F]');

        sendTelegramNotification('RAIN_START');

        runRainCycle();
    }

    function stopRainBot() {
        rainState.isRunning = false;
        prevRainRunning = false;

        if (rainState.scheduledTimeout) {
            clearTimeout(rainState.scheduledTimeout);
            rainState.scheduledTimeout = null;
        }

        rainState.joinedRains = new Set();
        rainState.successCount = 0;
        rainState.failCount = 0;
        fishingDone = false;
        fishingTotalBets = 0;
        updateFishingUI(false, 'Pending');

        stopRainTimer();
        stopChatRefreshLoop();
        stopHumanBehavior();

        addLog('Rain catcher stopped', '#f87171', '[R]');
        updateRainUI();
    }

