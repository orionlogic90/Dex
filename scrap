    async function fetchRakebackStatus() {
        try {
            const response = await fetch('https://api.dicey.com/graphql', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                credentials: 'include',
                body: JSON.stringify({
                    operationName: 'GetUserRakeback',
                    query: `
                        query GetUserRakeback {
                            userRakeback {
                                balances {
                                    currency
                                    balance {
                                        currencyCode
                                        smallestUnits
                                    }
                                }
                                totalValueUsd
                            }
                        }
                    `
                })
            });
            const data = await response.json();
            return data?.data?.userRakeback || null;
        } catch(e) {
            return null;
        }
    }

    async function fetchFreeSpins() {
        try {
            const response = await fetch('https://api.dicey.com/graphql', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                credentials: 'include',
                body: JSON.stringify({
                    operationName: 'MyFreespins',
                    query: `
                        query MyFreespins($filter: MyFreespinsFilter) {
                            myFreespins(filter: $filter) {
                                issueId
                                freespinsQuantity
                                status
                            }
                        }
                    `,
                    variables: { filter: { statuses: ["Issued"] } }
                })
            });
            const data = await response.json();
            return data?.data?.myFreespins || [];
        } catch(e) {
            return [];
        }
