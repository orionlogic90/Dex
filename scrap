    // ============================================================
    // DECODE JWT & FETCH FUNCTIONS
    // ============================================================
    function decodeJWT(token) {
        try {
            const parts = token.split('.');
            if (parts.length !== 3) return null;
            const payload = parts[1];
            const base64 = payload.replace(/-/g, '+').replace(/_/g, '/');
            const jsonPayload = decodeURIComponent(
                atob(base64)
                    .split('')
                    .map(c => '%' + ('00' + c.charCodeAt(0).toString(16)).slice(-2))
                    .join('')
            );
            return JSON.parse(jsonPayload);
        } catch(e) {
            return null;
        }
    }

    async function fetchIntercomJWT() {
        try {
            const response = await fetch('https://api.dicey.com/graphql', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                credentials: 'include',
                body: JSON.stringify({
                    operationName: 'IntercomJwt',
                    query: `query IntercomJwt { intercomJwt { jwt } }`
                })
            });
            const data = await response.json();
            return data?.data?.intercomJwt?.jwt || null;
        } catch(e) {
            return null;
        }
    }

    async function fetchVIPStatus() {
        try {
            const response = await fetch('https://api.dicey.com/graphql', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                credentials: 'include',
                body: JSON.stringify({
                    operationName: 'GetUserVipStatus',
                    query: `
                        query GetUserVipStatus {
                            getUserVipStatus {
                                userVipStatus {
                                    tierLevel
                                    tierSubLevel
                                    tierPoints
                                    progressPercent
                                }
                            }
                        }
                    `
                })
            });
            const data = await response.json();
            return data?.data?.getUserVipStatus?.userVipStatus || null;
        } catch(e) {
            return null;
        }
    }

    // ============================================================
    // DRAGGABLE
    // ============================================================
    let isDragging = false;
    let dragOffsetX, dragOffsetY;

    const header = document.getElementById('dicey-header');

    header.addEventListener('mousedown', function(e) {
        if (e.target.closest('button')) return;
        isDragging = true;
        const rect = container.getBoundingClientRect();
        dragOffsetX = e.clientX - rect.left;
        dragOffsetY = e.clientY - rect.top;
        container.style.cursor = 'grabbing';
        e.preventDefault();
    });

    document.addEventListener('mousemove', function(e) {
        if (!isDragging) return;
        let x = e.clientX - dragOffsetX;
        let y = e.clientY - dragOffsetY;
        x = Math.max(0, Math.min(window.innerWidth - container.offsetWidth, x));
        y = Math.max(0, Math.min(window.innerHeight - container.offsetHeight, y));
        container.style.left = x + 'px';
