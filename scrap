    // ============================================================
    async function updateRewardsUI() {
        try {
            const rakeback = await fetchRakebackStatus();
            const rakebackEl = document.getElementById('dicey-rakeback-display');
            if (rakebackEl && rakeback) {
                const total = rakeback.balances?.reduce(function(sum, b) {
                    return sum + (b.balance.smallestUnits / 1000000);
                }, 0) || 0;
                rakebackEl.textContent = '$' + total.toFixed(4);
                rakebackEl.style.color = total > 0 ? '#4ade80' : '#666';
            }

            const rewards = await fetchTotalRewards();
            const totalEl = document.getElementById('dicey-total-rewards');
            if (totalEl && rewards) {
                totalEl.textContent = '$' + parseFloat(rewards.totalAllRewardsUsd || 0).toFixed(2);
            }

            const freespins = await fetchFreeSpins();
            const freespinsEl = document.getElementById('dicey-freespins-display');
            if (freespinsEl) {
                const count = freespins?.length || 0;
                freespinsEl.textContent = count;
                freespinsEl.style.color = count > 0 ? '#ffd700' : '#666';
            }

            const vip = await fetchVIPStatus();
            const vipProgressEl = document.getElementById('dicey-vip-progress');
            const vipPointsEl = document.getElementById('dicey-vip-points');
            if (vipProgressEl && vip) {
                vipProgressEl.style.width = Math.min(vip.progressPercent || 0, 100) + '%';
            }
            if (vipPointsEl && vip) {
                const points = parseFloat(vip.tierPoints || 0);
                const targets = [10000, 25000, 50000, 75000, 100000, 150000, 250000, 350000, 500000, 750000, 1000000];
                let nextTarget = 10000;
                for (var i = 0; i < targets.length; i++) {
                    if (points < targets[i]) {
                        nextTarget = targets[i];
                        break;
                    }
                }
                vipPointsEl.textContent = points.toFixed(0) + ' pts → ' + nextTarget.toLocaleString();
            }

        } catch(e) {
            console.error('Failed to update rewards UI:', e);
        }
    }

    // ============================================================
    // REWARDS - AUTO CLAIM
    // ============================================================
    let autoClaimEnabled = true;
    let autoClaimInterval = null;

    async function autoClaimAllRewards() {
        if (!isLicensed) {
            addLog('[!] License required for auto claim', '#f87171', '[!]');
            return;
        }

        if (!autoClaimEnabled) return;

        addLog('[CLAIM] Auto claim cycle...', '#60a5fa', '[🔄]');

        try {
            const rakeback = await fetchRakebackStatus();
            if (rakeback?.balances) {
                for (const balance of rakeback.balances) {
                    const amount = balance.balance.smallestUnits / 1000000;
                    if (amount > 0.0001) {
                        await claimRakeback(balance.currency);
                        await sleep(500);
                    }
                }
            }

            const freespins = await fetchFreeSpins();
            if (freespins && freespins.length > 0) {
                for (const spin of freespins) {
                    if (spin.status === 'issued') {
                        await claimFreespins(spin.issueId);
                        await sleep(800);
                    }
                }
            }

            await updateRewardsUI();

        } catch(e) {
            addLog('[CLAIM] Auto claim error: ' + e.message, '#ff6b6b', '[❌]');
        }
    }

    function toggleAutoClaim() {
        autoClaimEnabled = !autoClaimEnabled;
        const btn = document.getElementById('dicey-auto-claim-toggle');
        if (btn) {
            btn.textContent = autoClaimEnabled ? '🔄 AUTO: ON' : '🔄 AUTO: OFF';
            btn.style.background = autoClaimEnabled ? '#4ade80' : '#ff6b6b';
            btn.style.color = autoClaimEnabled ? '#000' : '#fff';
        }

        if (autoClaimEnabled) {
            if (autoClaimInterval) {
                clearInterval(autoClaimInterval);
            }
            autoClaimInterval = setInterval(autoClaimAllRewards, 60 * 60 * 1000);
            addLog('[CLAIM] Auto claim enabled (every 1 hour)', '#4ade80', '[🔄]');
        } else {
            if (autoClaimInterval) {
                clearInterval(autoClaimInterval);
                autoClaimInterval = null;
            }
            addLog('[CLAIM] Auto claim disabled', '#ff6b6b', '[⏹️]');
        }
    }

