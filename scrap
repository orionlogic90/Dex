                return false;
            }
            
            const userId = stream.userId;
            const apiKey = stream.apiKey || 'gszqy9y9nr3e3';
            const messageId = userId + '-' + generateUUID();
            
            const url = 'https://chat.stream-io-api.com/channels/messaging/lobby-en/message' +
                '?user_id=' + userId +
                '&connection_id=' + connectionId +
                '&api_key=' + apiKey;
            
            const payload = {
                message: {
                    id: messageId,
                    text: message,
                    type: 'regular'
                }
            };
            
            const response = await fetch(url, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'Authorization': stream.token,
                    'stream-auth-type': 'jwt',
                    'Origin': 'https://dicey.com',
                    'User-Agent': navigator.userAgent,
