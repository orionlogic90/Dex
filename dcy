    var Human = {
        profile: 'casual',
        activityCount: 0,
        lastAction: Date.now(),
        sessionStart: Date.now(),

        getDelay: function(baseMs, profileOverride) {
            var p = profileOverride || this.profile;
            var profiles = {
                casual: { jitter: 0.5, hesitate: 0.15, extra: 800 },
                focused: { jitter: 0.3, hesitate: 0.05, extra: 400 },
                distracted: { jitter: 0.7, hesitate: 0.25, extra: 1200 },
                tired: { jitter: 0.6, hesitate: 0.30, extra: 1500 },
                excited: { jitter: 0.2, hesitate: 0.02, extra: 200 }
            };
            var data = profiles[p] || profiles.casual;

            var delay = baseMs * (1 + (Math.random() * 2 - 1) * data.jitter);
            if (Math.random() < data.hesitate) {
                delay += data.extra * Math.random();
            }

            var elapsed = Date.now() - this.lastAction;
            if (elapsed > 300000) delay *= 1.2;
            if (this.activityCount > 50) {
                delay *= 1 + (this.activityCount - 50) * 0.001;
            }

            this.activityCount++;
            this.lastAction = Date.now();
            return Math.max(50, Math.min(delay, 5000));
        },

        think: function(profile) {
            var delay = this.getDelay(200, profile);
            return new Promise(function(r) { setTimeout(r, delay); });
        },

        quickRespond: function() {
            var delay = this.getDelay(50, 'excited');
            return new Promise(function(r) { setTimeout(r, delay); });
        },

        patientWait: function(baseMs) {
            var delay = this.getDelay(baseMs, 'distracted');
            return new Promise(function(r) { setTimeout(r, delay); });
        },

        rotateProfile: function() {
            var hour = new Date().getHours();
            var newProfile;
            if (hour < 6) newProfile = 'tired';
            else if (hour < 9) newProfile = 'casual';
            else if (hour < 12) newProfile = 'focused';
            else if (hour < 14) newProfile = 'distracted';
            else if (hour < 18) newProfile = 'excited';
            else if (hour < 21) newProfile = 'focused';
            else newProfile = 'tired';

            if (Math.random() < 0.1) {
                var moods = ['casual', 'focused', 'distracted', 'tired', 'excited'];
                var randomMood = moods[Math.floor(Math.random() * moods.length)];
                if (randomMood !== this.profile) newProfile = randomMood;
            }

            if (newProfile !== this.profile) {
                this.profile = newProfile;
                addLog('Mood: ' + newProfile, '#60a5fa', 'mood');
            }
        },

        doRandomActivity: function() {
            var activities = [
                { name: 'check_phone', chance: 0.10, duration: function() { return 10000 + Math.random() * 20000; }, action: function() { addLog('Check phone', '#888', 'phone'); } },
                { name: 'check_balance', chance: 0.08, duration: function() { return 3000 + Math.random() * 5000; }, action: function() { addLog('Check balance', '#888', 'balance'); updateUserInfo(); } },
                { name: 'check_time', chance: 0.05, duration: function() { return 2000 + Math.random() * 3000; }, action: function() { addLog('Check time: ' + new Date().toLocaleTimeString(), '#888', 'time'); } },
                { name: 'scroll', chance: 0.08, duration: function() { return 5000 + Math.random() * 10000; }, action: function() { addLog('Scroll', '#888', 'scroll'); } },
                { name: 'stretch', chance: 0.03, duration: function() { return 8000 + Math.random() * 12000; }, action: function() { addLog('Stretch', '#888', 'stretch'); } },
                { name: 'distracted', chance: 0.06, duration: function() { return 10000 + Math.random() * 20000; }, action: function() { addLog('Distracted', '#888', 'distracted'); } }
            ];

            var elapsed = Date.now() - this.sessionStart;
            var fatigue = Math.min(elapsed / 3600000, 3);
            var totalChance = 0;
            for (var i = 0; i < activities.length; i++) {
                totalChance += activities[i].chance;
            }
            totalChance = totalChance * Math.min(fatigue, 2);

            if (Math.random() > totalChance) return Promise.resolve();

            var available = [];
            for (var j = 0; j < activities.length; j++) {
                if (Math.random() < activities[j].chance) {
                    available.push(activities[j]);
                }
            }
            if (!available.length) return Promise.resolve();

            var activity = available[Math.floor(Math.random() * available.length)];
            activity.action();
            var that = this;
            return sleep(activity.duration()).then(function() {
                addLog('Back to focus', '#888', 'focus');
                return that.think('focused');
            });
        },

        shouldDoActivity: function() {
            var elapsed = Date.now() - this.sessionStart;
            var fatigue = Math.min(elapsed / 3600000, 3);
            var chance = 0.10 * Math.min(fatigue, 2);
            return Math.random() < chance;
        }
    };

