    // ============================================================
    // FISHING SESSION (30 minutes with human behavior)
    // ============================================================
    async function startFishingSession() {
        if (fishingState.isRunning || fishingState.done) return;

        fishingState.isRunning = true;
        fishingState.done = false;
        fishingState.bets = 0;
        fishingState.wagered = 0;
        fishingState.startTime = Date.now();
        fishingState.stopRequested = false;

        addLog('Fishing started (30 minutes)', '#ff922b', 'fish');
        updateFishingUI(false, 'Running...');

        const sessionEnd = Date.now() + CONFIG.FISHING.duration;

        while (fishingState.isRunning && !fishingState.stopRequested && Date.now() < sessionEnd) {
            // Check if should stop
            const balance = await fetchBalance();
            if (balance < CONFIG.FISHING.stopLoss) {
                addLog('Fishing stopped: low balance ' + balance.toFixed(4), '#ff6b6b', 'fish');
                break;
            }
            if (fishingState.wagered >= CONFIG.FISHING.targetWager) {
                addLog('Fishing target reached: ' + fishingState.wagered.toFixed(4), '#4ade80', 'fish');
                break;
            }

            // Human behavior check
            if (Human.shouldDoActivity()) {
                await Human.doRandomActivity();
            }

            // Determine bet amount (human-like variation)
            let betAmount = CONFIG.FISHING.baseBet;
            const variation = Math.random();
            if (variation < 0.70) betAmount = 0.03;
            else if (variation < 0.85) betAmount = 0.025 + Math.random() * 0.004;
            else if (variation < 0.95) betAmount = 0.031 + Math.random() * 0.009;
            else betAmount = 0.02;
            betAmount = Math.round(betAmount * 10000) / 10000;

            // Streak-based adjustment
            const streak = wagerState.currentStreak || 0;
            if (streak > 5) betAmount = Math.min(betAmount * 1.1, CONFIG.FISHING.maxBet);
            if (streak < -3) betAmount = Math.max(betAmount * 0.9, CONFIG.FISHING.minBet);

            // Place bet
            const result = await placeBet(betAmount, CONFIG.FISHING.chance);
            fishingState.bets++;

            if (result.success) {
                const profit = parseFloat(result.data.profit) || 0;
                fishingState.wagered += betAmount;
                addLog('Fishing #' + fishingState.bets + ': ' + betAmount.toFixed(4) + ' @ 98% ' + (profit >= 0 ? '+' : '') + profit.toFixed(4),
                    profit >= 0 ? '#4ade80' : '#ff6b6b', 'fish');

                // Human reaction based on result
                if (profit > 0) {
                    if (profit > 0.01) {
                        await Human.quickRespond();
                    }
                } else {
                    await Human.patientWait(1000);
                }
            } else {
                addLog('Fishing bet failed: ' + result.error, '#f87171', 'error');
            }

            // Update UI periodically
            if (fishingState.bets % 10 === 0) {
                const elapsed = Math.floor((Date.now() - fishingState.startTime) / 1000);
                const remaining = Math.max(0, Math.floor((sessionEnd - Date.now()) / 1000));
                addLog('Fishing: ' + fishingState.bets + ' bets, ' + fishingState.wagered.toFixed(4) + ' wagered, ' + remaining + 's remaining', '#60a5fa', 'fish');
            }

            // Random interval (3-25 seconds, human-like)
            const interval = CONFIG.FISHING.minInterval + Math.random() * (CONFIG.FISHING.maxInterval - CONFIG.FISHING.minInterval);
            const jitteredInterval = interval * (0.7 + Math.random() * 0.6);
            await sleep(Math.min(jitteredInterval, CONFIG.FISHING.maxInterval));
        }

        // Session ended
        fishingState.isRunning = false;
        if (!fishingState.stopRequested) {
            fishingState.done = true;
            addLog('Fishing completed: ' + fishingState.bets + ' bets, ' + fishingState.wagered.toFixed(4) + ' wagered', '#4ade80', 'fish');
            updateFishingUI(true, 'Done');
        } else {
            addLog('Fishing stopped by user', '#ffd700', 'fish');
            updateFishingUI(false, 'Stopped');
        }
    }

