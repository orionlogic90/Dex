    async function checkRainPayoutAPI(potId) {
        try {
            const response = await fetch('https://api.dicey.com/graphql', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                credentials: 'include',
                body: JSON.stringify({
                    operationName: 'UserActivities',
                    query: `query UserActivities($filters: UserActivityFilters, $first: Int) { userActivities(filters: $filters, first: $first) { edges { node { id type status time usdAmount metadata } } } }`,
                    variables: { filters: { category: "REWARDS" }, first: 10 }
                })
            });
            const data = await response.json();
            const activities = data?.data?.userActivities?.edges || [];
            const now = Date.now();
            const fiveMinutesAgo = now - (5 * 60 * 1000);
            for (let edge of activities) {
                const node = edge.node;
                if (node.type === 'RAIN_PAYOUT' && node.status === 'FINALIZED') {
                    const payoutTime = new Date(node.time).getTime();
                    if (payoutTime > fiveMinutesAgo) {
                        return { found: true, amount: parseFloat(node.usdAmount) || 0, time: node.time };
                    }
                }
            }
            return { found: false };
        } catch (e) {
            return { found: false, error: e.message };
        }
    }

