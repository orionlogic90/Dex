    // ============================================================
    // WAGER CORE
    // ============================================================
    async function doWagerBet() {
        if (!wagerState.isRunning || wagerState.isPaused || wagerState.stopRequested) return null;

        const balance = await fetchBalance();
        if (balance > 0) wagerState.currentBalance = balance;

        const layer1Chance = parseFloat($('dicey-layer1-chance')?.value || 98);
        const layer1Bet = parseFloat($('dicey-layer1-bet')?.value || 0.01);
        const layer1Multiplier = parseFloat($('dicey-layer1-multiplier')?.value || 2.0);
        const layer2ChanceStart = parseFloat($('dicey-layer2-chance-start')?.value || 65);
        const layer2ChanceMax = parseFloat($('dicey-layer2-chance-max')?.value || 99);
        const layer2ChanceIncrement = parseFloat($('dicey-layer2-chance-increment')?.value || 1.0);
        const layer2Multiplier = parseFloat($('dicey-layer2-multiplier')?.value || 1.1);
        const backStreak = parseInt($('dicey-back-streak')?.value || 1);
        const backProfit = parseFloat($('dicey-back-profit')?.value || 0);

        if (wagerState.totalBets === 0) {
            wagerState.startBalance = wagerState.currentBalance || 3;
            wagerState.currentBet = layer1Bet;
            wagerState.currentLayer = 1;
            wagerState.lossRecovery = 0;
            wagerState.totalLossInL2 = 0;
            wagerState.startTime = Date.now();
            if (wagerState.timerInterval) clearInterval(wagerState.timerInterval);
            wagerState.timerInterval = setInterval(updateWagerTimer, 1000);
        }

        wagerState.totalBets++;

        let betAmount, chance;
        if (wagerState.currentLayer === 1) {
            betAmount = wagerState.currentBet;
            chance = layer1Chance;
            wagerState.layer1Bets++;
        } else {
            betAmount = wagerState.currentBet;
            chance = wagerState.layer2CurrentChance;
            wagerState.layer2Bets++;
        }

        const result = await placeBet(betAmount, chance);
        if (!result.success) {
            addLog('Bet failed: ' + result.error, '#ff6b6b', 'error');
            updateWagerUI();
            return null;
        }

        const data = result.data;
        wagerState.wagered += betAmount;
        const profitNum = parseFloat(data.profit) || 0;
        wagerState.currentBalance += profitNum;

        const realBalance = await fetchBalance();
        if (realBalance > 0) wagerState.currentBalance = realBalance;

        addLog('Bet #' + wagerState.totalBets + ': ' + betAmount.toFixed(4) + ' @ ' + chance + '% ' + (profitNum >= 0 ? '+' : '') + profitNum.toFixed(4), profitNum >= 0 ? '#4ade80' : '#ff6b6b', 'bet');

        if (data.isWin) {
            wagerState.totalWins++;
            wagerState.currentStreak = wagerState.currentStreak > 0 ? wagerState.currentStreak + 1 : 1;
            if (wagerState.currentLayer === 1) {
                wagerState.layer1Wins++;
                wagerState.currentBet = layer1Bet;
                wagerState.lossRecovery = 0;
                wagerState.totalLossInL2 = 0;
            } else {
                wagerState.layer2Wins++;
                wagerState.lossRecovery += profitNum;
                if (backProfit > 0 && wagerState.lossRecovery >= backProfit) {
                    addLog('L2->L1: Recovery ' + wagerState.lossRecovery.toFixed(4), '#00e5c0', 'layer');
                    wagerState.currentLayer = 1;
                    wagerState.currentBet = layer1Bet;
                    wagerState.currentStreak = 0;
                    wagerState.lossRecovery = 0;
                    wagerState.totalLossInL2 = 0;
                    wagerState.layer2CurrentChance = layer2ChanceStart;
                    wagerState.layer2BetCount = 0;
                } else if (wagerState.currentStreak >= backStreak) {
                    addLog('L2->L1: Win streak ' + wagerState.currentStreak, '#00e5c0', 'layer');
                    wagerState.currentLayer = 1;
                    wagerState.currentBet = layer1Bet;
                    wagerState.currentStreak = 0;
                    wagerState.lossRecovery = 0;
                    wagerState.totalLossInL2 = 0;
                    wagerState.layer2CurrentChance = layer2ChanceStart;
                    wagerState.layer2BetCount = 0;
                } else {
                    wagerState.currentBet = parseFloat($('dicey-layer2-bet')?.value || 0.01);
                }
            }
        } else {
            wagerState.totalLosses++;
            wagerState.currentStreak = wagerState.currentStreak < 0 ? wagerState.currentStreak - 1 : -1;
            if (wagerState.currentLayer === 1) {
                const newBet = wagerState.currentBet * layer1Multiplier;
                wagerState.currentBet = Math.max(newBet, 0.01);
                wagerState.currentLayer = 2;
                wagerState.lossRecovery = 0;
                wagerState.totalLossInL2 = 0;
                wagerState.layer2CurrentChance = layer2ChanceStart;
                wagerState.layer2BetCount = 0;
                addLog('L1->L2: Loss streak ' + Math.abs(wagerState.currentStreak), '#ff922b', 'layer');
            } else {
                wagerState.totalLossInL2 += Math.abs(profitNum);
                wagerState.currentBet = wagerState.currentBet * layer2Multiplier;
                wagerState.layer2BetCount++;
                const newChance = wagerState.layer2CurrentChance + layer2ChanceIncrement;
                wagerState.layer2CurrentChance = newChance >= layer2ChanceMax ? layer2ChanceStart : newChance;
                if (Math.abs(wagerState.currentStreak) >= 10) {
                    addLog('Emergency L2->L1', '#ff6b6b', 'emergency');
                    wagerState.currentLayer = 1;
                    wagerState.currentBet = layer1Bet;
                    wagerState.currentStreak = 0;
                    wagerState.lossRecovery = 0;
                    wagerState.totalLossInL2 = 0;
                    wagerState.layer2CurrentChance = layer2ChanceStart;
                    wagerState.layer2BetCount = 0;
                }
            }
        }

        const targetProfitPercent = parseFloat($('dicey-target-profit')?.value || 100);
        const stopLossPercent = parseFloat($('dicey-stop-loss')?.value || 90);
        const targetProfit = wagerState.startBalance * (targetProfitPercent / 100);
        const stopLoss = wagerState.startBalance * (1 - stopLossPercent / 100);
        const wagerTarget = getConvertedTarget();

        if (wagerState.wagered >= wagerTarget) {
            addLog('Target reached: ' + wagerTarget.toFixed(4) + ' ' + getCurrency(), '#00e5c0', 'target');
            stopWagerBot();
            return null;
        }
        if (wagerState.currentBalance - wagerState.startBalance >= targetProfit) {
            addLog('Profit target +' + targetProfitPercent + '% reached', '#00e5c0', 'profit');
            stopWagerBot();
            return null;
        }
        if (wagerState.currentBalance <= stopLoss) {
            addLog('Stop loss -' + stopLossPercent + '%', '#ff6b6b', 'stop');
            stopWagerBot();
            return null;
        }
        const stopOnWin = $('dicey-stop-on-win');
        if (stopOnWin && stopOnWin.checked && wagerState.currentStreak >= 5) {
            addLog('Stop on win streak: ' + wagerState.currentStreak, '#ffd700', 'stop');
            stopWagerBot();
            return null;
        }

        updateWagerUI();
        return data;
    }

    // ============================================================
    // WAGER LOOP WITH HUMAN BEHAVIOR
    // ============================================================
    async function wagerLoop() {
        if (!wagerState.isRunning || wagerState.isPaused || wagerState.isLooping || wagerState.stopRequested) return;
        wagerState.isLooping = true;

        try {
            if (await Human.shouldDoActivity()) {
                await Human.doRandomActivity();
            }

            if (wagerState.totalBets % 20 === 0) {
                Human.rotateProfile();
            }

            await doWagerBet();

            const autoContinue = $('dicey-auto-continue');
            if (autoContinue && autoContinue.checked && wagerState.isRunning && !wagerState.isPaused) {
                const baseCooldown = parseInt($('dicey-cooldown')?.value || 0);
                const delay = Human.getDelay(baseCooldown);
                wagerState.isLooping = false;
                setTimeout(wagerLoop, delay);
            } else {
                wagerState.isLooping = false;
            }
        } catch (e) {
            wagerState.isLooping = false;
            addLog('Wager error: ' + e.message, '#f87171', 'error');
            setTimeout(wagerLoop, Human.getDelay(500));
        }
    }

    // ============================================================
    // WAGER CONTROL FUNCTIONS
    // ============================================================
    function startWagerBot() {
        if (!isLicensed) {
            addLog('License required', '#f87171', 'error');
            return;
        }
        if (wagerState.isRunning && !wagerState.isPaused) {
            addLog('Already running', '#ffd700', 'info');
            return;
        }
        if (wagerState.isPaused) {
            wagerState.isPaused = false;
            wagerState.isRunning = true;
            addLog('Resumed', '#00e5c0', 'resume');
            updateWagerUI();
            setTimeout(wagerLoop, 0);
            return;
        }

        const layer1Bet = parseFloat($('dicey-layer1-bet')?.value || 0.01);
        if (layer1Bet <= 0) {
            addLog('Set valid bet amount', '#ff6b6b', 'error');
            return;
        }

        wagerState.isRunning = true;
        wagerState.isPaused = false;
        wagerState.stopRequested = false;
        wagerState.totalBets = 0;
        wagerState.totalWins = 0;
        wagerState.totalLosses = 0;
        wagerState.currentStreak = 0;
        wagerState.currentLayer = 1;
        wagerState.currentBet = layer1Bet;
        wagerState.wagered = 0;
        wagerState.layer1Bets = 0;
        wagerState.layer2Bets = 0;
        wagerState.layer1Wins = 0;
        wagerState.layer2Wins = 0;
        wagerState.lossRecovery = 0;
        wagerState.totalLossInL2 = 0;
        wagerState.isLooping = false;
        wagerState.layer2CurrentChance = parseFloat($('dicey-layer2-chance-start')?.value || 65);
        wagerState.layer2BetCount = 0;
        wagerState.layer2ResetCount = 0;

        fetchBalance().then(balance => {
            if (balance > 0) { wagerState.currentBalance = balance; wagerState.startBalance = balance; }
            else { wagerState.currentBalance = 3; wagerState.startBalance = 3; }
        });

        wagerState.startTime = Date.now();
        if (wagerState.timerInterval) clearInterval(wagerState.timerInterval);
        wagerState.timerInterval = setInterval(updateWagerTimer, 1000);

        addLog('Wager started: L1 ' + layer1Bet + ' ' + getCurrency(), '#00e5c0', 'start');
        updateWagerUI();
        setTimeout(wagerLoop, 0);
    }

    function pauseWagerBot() {
        if (!wagerState.isRunning) {
            addLog('Not running', '#ffd700', 'info');
            return;
        }
        wagerState.isPaused = !wagerState.isPaused;
        addLog(wagerState.isPaused ? 'Paused' : 'Resumed', '#ffd700', 'pause');
        updateWagerUI();
        if (!wagerState.isPaused) {
            setTimeout(wagerLoop, 0);
        }
    }

    function stopWagerBot() {
        wagerState.stopRequested = true;
        wagerState.isRunning = false;
        wagerState.isPaused = false;
        wagerState.isLooping = false;
        if (wagerState.timerInterval) {
            clearInterval(wagerState.timerInterval);
            wagerState.timerInterval = null;
        }
        const profit = wagerState.currentBalance - wagerState.startBalance;
        addLog('Wager stopped: ' + (profit >= 0 ? '+' : '') + profit.toFixed(4) + ' ' + getCurrency(), '#ffd700', 'stop');
        addLog('Total wagered: ' + wagerState.wagered.toFixed(4) + ' ' + getCurrency(), '#a0a0a0', 'total');
        addLog('Bets: ' + wagerState.totalBets + ' | L1: ' + wagerState.layer1Bets + ' | L2: ' + wagerState.layer2Bets, '#a0a0a0', 'bets');
        updateWagerUI();
        wagerState.stopRequested = false;
    }

    function resetWagerBot() {
        stopWagerBot();
        wagerState.totalBets = 0;
        wagerState.totalWins = 0;
        wagerState.totalLosses = 0;
        wagerState.currentStreak = 0;
        wagerState.wagered = 0;
        wagerState.layer1Bets = 0;
        wagerState.layer2Bets = 0;
        wagerState.layer1Wins = 0;
        wagerState.layer2Wins = 0;
        wagerState.lossRecovery = 0;
        wagerState.totalLossInL2 = 0;
        wagerState.currentLayer = 1;
        wagerState.currentBet = parseFloat($('dicey-layer1-bet')?.value || 0.01);
        wagerState.layer2CurrentChance = parseFloat($('dicey-layer2-chance-start')?.value || 65);
        wagerState.layer2BetCount = 0;
        wagerState.layer2ResetCount = 0;
        fetchBalance().then(balance => {
            if (balance > 0) { wagerState.currentBalance = balance; wagerState.startBalance = balance; }
        });
        addLog('Reset', '#ffd700', 'reset');
        updateWagerUI();
    }

