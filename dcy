    // ============================================================
    // INIT
    // ============================================================
    function init() {
        setupUI();
        bindEvents();

        const licenseInput = $('dicey-license');
        const usernameInput = $('dicey-username');

        // Load saved license
        const savedLicense = localStorage.getItem('dicey_license');
        const savedUsername = localStorage.getItem('dicey_username');
        if (savedLicense && licenseInput) licenseInput.value = savedLicense;
        if (savedUsername && usernameInput) usernameInput.value = savedUsername;

        // Initial state
        wagerState.currentBalance = 3;
        wagerState.startBalance = 3;
        updateWagerUI();
        updateRainUI();
        updateFishingUI(false, 'Pending');

        // Check license after load
        setTimeout(() => {
            if (licenseInput?.value && usernameInput?.value) {
                updateLicenseStatus();
            }
        }, 500);

        // Restore state after 2 seconds
        setTimeout(() => {
            const hasState = localStorage.getItem('dicey_state');
            if (hasState) {
                addLog('Found saved state, restoring...', '#60a5fa', 'init');
                setTimeout(() => {
                    const restored = restoreState();
