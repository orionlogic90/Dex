    function fetchBalance() {
        return fetch('https://api.dicey.com/graphql', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            credentials: 'include',
            body: JSON.stringify({
                operationName: 'UserBalances',
                query: 'query UserBalances { userBalances { balances { currency playableBalance { smallestUnits currencyCode } } } }'
            })
        }).then(function(response) {
            return response.json();
        }).then(function(data) {
            var balances = data?.data?.userBalances?.balances || [];
            var currency = getCurrency();
            for (var i = 0; i < balances.length; i++) {
                if (balances[i].currency === currency) {
                    return balances[i].playableBalance.smallestUnits / 1000000;
                }
            }
            return 0;
        }).catch(function() {
            return 0;
        });
    }

    function placeBet(betAmount, chance) {
        var cryptoCurrency = getCurrency();
        var targetNumber = Math.floor((chance / 100) * 10000);
        var query = 'mutation PlaceDiceBet($input: DiceBetInput!) { placeDiceBet(input: $input) { roundId activityId betAmount targetNumber targetNumberLower targetNumberUpper rollMode rolledNumber multiplier winAmount isWin profit timestamp } }';
        var variables = {
            input: {
                betAmount: String(betAmount),
                cryptoCurrency: cryptoCurrency,
                nonce: generateUUID(),
                rollMode: 'Under',
                targetNumber: targetNumber
            }
        };
        return fetch('https://api.dicey.com/graphql', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
            credentials: 'include',
            body: JSON.stringify({ operationName: 'PlaceDiceBet', query: query, variables: variables })
        }).then(function(response) {
            if (!response.ok) throw new Error('HTTP ' + response.status);
            return response.json();
        }).then(function(data) {
            if (data.errors) throw new Error(data.errors[0].message);
            return { success: true, data: data.data.placeDiceBet };
        }).catch(function(error) {
            return { success: false, error: error.message };
        });
    }

