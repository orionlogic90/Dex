    function updateRainTimer(rainData) {
        var nextEl = $('dicey-rain-next');
        var endsEl = $('dicey-rain-ends');
        var amountEl = $('dicey-rain-amount');
        var participantsEl = $('dicey-rain-participants');

        if (!rainData) {
            if (nextEl) nextEl.textContent = 'Next: --';
            if (endsEl) endsEl.textContent = 'Ends: --';
            if (amountEl) amountEl.textContent = '--';
            if (participantsEl) participantsEl.textContent = '--';
            return;
        }

        var now = new Date();
        var startsAt = new Date(rainData.startsAt);
        var settlesAt = new Date(rainData.settlesAt);

        if (amountEl) amountEl.textContent = '$' + parseFloat(rainData.totalUsdAmount || 0).toFixed(2);
        if (participantsEl) participantsEl.textContent = (rainData.participantCount || 0);

        if (rainData.status === 'Settled' || now > settlesAt) {
            if (nextEl) nextEl.textContent = 'Finished';
            if (endsEl) endsEl.textContent = '--';
            return;
        }

        if (now >= startsAt && now <= settlesAt) {
            var timeLeft = settlesAt.getTime() - now.getTime();
            var mins = String(Math.floor(timeLeft / 60000)).padStart(2, '0');
            var secs = String(Math.floor((timeLeft % 60000) / 1000)).padStart(2, '0');
            if (nextEl) nextEl.textContent = 'Active';
            if (endsEl) endsEl.textContent = 'Ends: ' + mins + ':' + secs;
        } else if (now < startsAt) {
            var timeUntil = startsAt.getTime() - now.getTime();
            var mins2 = String(Math.floor(timeUntil / 60000)).padStart(2, '0');
            var secs2 = String(Math.floor((timeUntil % 60000) / 1000)).padStart(2, '0');
            if (nextEl) nextEl.textContent = 'Next: ' + mins2 + ':' + secs2;
            if (endsEl) endsEl.textContent = 'Starts: ' + startsAt.toLocaleTimeString();
        }
    }

    function updatePayoutUI(result) {
        var winEl = $('dicey-last-rain-win');
        var timeEl = $('dicey-last-rain-time');
        if (winEl) {
            if (result.win) {
                winEl.textContent = '+' + result.usdAmount.toFixed(2) + ' USD WIN';
                winEl.style.color = '#4ade80';
            } else {
                winEl.textContent = 'No payout';
                winEl.style.color = '#888';
            }
        }
        if (timeEl && result.time) {
            var date = new Date(result.time);
