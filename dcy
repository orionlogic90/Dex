    // ============================================================
    // RAIN LOOP
    // ============================================================
    function rainLoop() {
        if (!rainState.isRunning || rainState.stopRequested) return;

        function scheduleCheck(delay) {
            if (rainState.checkTimeout) {
                clearTimeout(rainState.checkTimeout);
                rainState.checkTimeout = null;
            }
            if (!rainState.isRunning || rainState.stopRequested) return;
            rainState.checkTimeout = setTimeout(rainLoop, delay);
        }

        function processRain() {
            if (!rainState.isRunning || rainState.stopRequested) return;

            fetchRainSchedule().then(function(rainData) {
                if (!rainData) {
                    var delay = CONFIG.RAIN.checkIntervalMin + Math.random() * (CONFIG.RAIN.checkIntervalMax - CONFIG.RAIN.checkIntervalMin);
                    scheduleCheck(delay);
                    return;
                }

                var now = new Date();
                var startsAt = new Date(rainData.startsAt);
                var settlesAt = new Date(rainData.settlesAt);
                var potId = rainData.id;

                updateRainTimer(rainData);

                if (rainData.status === 'ACTIVE' && now >= startsAt && now <= settlesAt && !rainState.joinedRains.has(potId)) {
                    var amount = parseFloat(rainData.totalUsdAmount) || 0;

                    var shouldJoin = true;
                    if (amount < CONFIG.RAIN.skipSmallAmount) {
                        if (Math.random() < CONFIG.RAIN.skipRate) {
                            shouldJoin = false;
                            addLog('Skipping small rain: $' + amount.toFixed(2), '#888', 'rain');
                        }
                    }

                    var delayJoin = CONFIG.RAIN.joinDelayMin + Math.random() * (CONFIG.RAIN.joinDelayMax - CONFIG.RAIN.joinDelayMin);
                    addLog('Rain active: $' + amount.toFixed(2) + ' (joining in ' + Math.floor(delayJoin / 1000) + 's)', '#ff922b', 'rain');

                    setTimeout(function() {
                        if (!rainState.isRunning || rainState.stopRequested) {
                            scheduleCheck(30000);
                            return;
                        }
                        if (!shouldJoin) {
                            scheduleCheck(30000 + Math.random() * 30000);
                            return;
                        }

                        joinRainDirect(potId).then(function(result) {
                            if (result?.data?.joinRain?.joined) {
                                rainState.joinedRains.add(potId);
                                rainState.successCount++;
                                addLog('Joined rain!', '#4ade80', 'rain');
                                updateRainUI();

                                var timeToSettle = settlesAt.getTime() - Date.now();
                                setTimeout(function() {
                                    if (!rainState.isRunning || rainState.stopRequested) return;
                                    addLog('Checking payout...', '#ffd700', 'rain');
                                    checkRainPayoutAPI(potId).then(function(payout) {
                                        if (payout.found) {
                                            rainState.wins++;
                                            rainState.totalPayout += payout.amount;
                                            addLog('WIN! +' + payout.amount.toFixed(2) + ' USD', '#4ade80', 'rain');
                                            updatePayoutUI({ win: true, usdAmount: payout.amount, time: payout.time });
                                        } else {
                                            addLog('No payout for this rain', '#888', 'rain');
                                            updatePayoutUI({ win: false });
                                        }
                                        updateRainUI();
                                    });
                                }, timeToSettle + 2000);

                                scheduleCheck(timeToSettle + 10000);

                            } else {
                                var reason = result?.data?.joinRain?.ineligibleReason || 'Unknown';
                                rainState.failCount++;
                                addLog('Failed to join: ' + reason, '#f87171', 'rain');
                                updateRainUI();

                                var wagerKeywords = ['Wager', 'wagered', 'Insufficient', 'Requirement'];
                                var isWagerIssue = false;
                                for (var i = 0; i < wagerKeywords.length; i++) {
                                    if (reason.indexOf(wagerKeywords[i]) !== -1) isWagerIssue = true;
                                }

                                if (isWagerIssue) {
                                    addLog('Insufficient wager detected, auto wager...', '#ff922b', 'rain');
                                    doAutoWagerToTarget().then(function(success) {
                                        if (success) {
                                            addLog('Wager target reached, retrying...', '#4ade80', 'rain');
                                            scheduleCheck(3000 + Math.random() * 2000);
                                        } else {
                                            addLog('Failed to reach wager target', '#f87171', 'rain');
                                            scheduleCheck(60000 + Math.random() * 30000);
                                        }
                                    });
                                } else {
                                    scheduleCheck(30000 + Math.random() * 30000);
                                }
                            }
                        });
                    }, delayJoin);

                } else if (now < startsAt) {
                    var timeUntilStart = startsAt.getTime() - now.getTime();
                    var minutes = Math.floor(timeUntilStart / 60000);
                    if (minutes > 0) {
                        addLog('Next rain in ' + minutes + ' minutes', '#60a5fa', 'rain');
                    }
                    var checkDelay = timeUntilStart > 120000 ?
                        Math.min(timeUntilStart + 5000, 120000) :
                        5000 + Math.random() * 10000;
                    scheduleCheck(checkDelay);
                } else {
                    scheduleCheck(60000 + Math.random() * 60000);
                }
            }).catch(function(e) {
                addLog('Rain error: ' + e.message, '#f87171', 'error');
                scheduleCheck(30000 + Math.random() * 30000);
            });
        }

        if (Human.shouldDoActivity()) {
            Human.doRandomActivity().then(processRain);
        } else {
            processRain();
        }
    }

    // ============================================================
    // AUTO WAGER FOR RAIN ELIGIBILITY
    // ============================================================
    function doAutoWagerToTarget() {
        var target = CONFIG.FISHING.targetWager;
        var betAmount = 0.01;
        var chance = 98;
        var maxAttempts = 300;

        var currentWager = wagerState.wagered || 0;
        var attempts = 0;
        var successCount = 0;

        addLog('Auto wager started - Target: ' + target + ' ' + getCurrency(), '#60a5fa', 'auto');

        function doWager() {
            if (currentWager >= target || attempts >= maxAttempts || rainState.stopRequested) {
                addLog('Auto wager completed: ' + successCount + ' success, ' + (attempts - successCount) + ' failed', '#60a5fa', 'auto');
                return Promise.resolve(currentWager >= target);
            }

            attempts++;
            return placeBet(betAmount, chance).then(function(result) {
                if (result.success) {
                    successCount++;
                    currentWager += betAmount;
                    wagerState.wagered += betAmount;
                    if (attempts % 10 === 0 || currentWager >= target) {
                        addLog('Wager progress: ' + currentWager.toFixed(4) + '/' + target + ' ' + getCurrency() + ' (' + (currentWager / target * 100).toFixed(1) + '%)', '#ffd700', 'auto');
                        updateWagerUI();
                    }
                } else {
                    addLog('Wager failed: ' + result.error, '#ff922b', 'auto');
                }
                var delay = Human.getDelay(500);
                return sleep(delay).then(doWager);
            });
        }

        return doWager();
    }

    // ============================================================
    // RAIN CONTROL FUNCTIONS
    // ============================================================
    function startRainCatcher() {
        if (!isLicensed) {
            addLog('License required for rain catcher', '#f87171', 'error');
            return;
        }
        if (rainState.isRunning) {
            addLog('Already running', '#ffd700', 'info');
            return;
        }

        rainState.isRunning = true;
        rainState.stopRequested = false;
        rainState.joinedRains = new Set();
        rainState.successCount = 0;
        rainState.failCount = 0;
        rainState.wins = 0;
        rainState.totalPayout = 0;

        addLog('Rain catcher started', '#4ade80', 'rain');
        updateRainUI();

        if (!fishingState.done && !fishingState.isRunning) {
            addLog('Starting fishing session (30 minutes)', '#ff922b', 'fish');
            startFishingSession();
        }

        setTimeout(rainLoop, Human.getDelay(1000));
    }

    function stopRainCatcher() {
        rainState.isRunning = false;
        rainState.stopRequested = true;
        if (rainState.checkTimeout) {
            clearTimeout(rainState.checkTimeout);
            rainState.checkTimeout = null;
        }
        if (rainState.timerInterval) {
            clearInterval(rainState.timerInterval);
            rainState.timerInterval = null;
        }
        fishingState.stopRequested = true;
        fishingState.isRunning = false;
        addLog('Rain catcher stopped', '#f87171', 'rain');
        updateRainUI();
        updateFishingUI(fishingState.done, fishingState.done ? 'Done' : 'Stopped');
    }

