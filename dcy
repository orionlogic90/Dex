    async function fetchRainSchedule() {
        try {
            const response = await fetch('https://api.dicey.com/graphql', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                credentials: 'include',
                body: JSON.stringify({
                    operationName: 'RainPot',
                    query: `
                        query RainPot {
                            rainPot {
                                id
                                status
                                totalUsdAmount
                                startsAt
                                settlesAt
                                participantCount
                            }
                        }
                    `
                })
            });
            
            const data = await response.json();
