    // ============================================================
    // FETCH BALANCE (dari UserBalances)
    // ============================================================
    async function fetchBalance() {
        try {
            const response = await fetch('https://api.dicey.com/graphql', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                credentials: 'include',
                body: JSON.stringify({
                    operationName: 'UserBalances',
                    query: `
                        query UserBalances {
                            userBalances {
                                balances {
                                    currency
                                    playableBalance {
                                        smallestUnits
                                        currencyCode
                                    }
                                }
                            }
                        }
                    `
                })
            });
            
            const data = await response.json();
            const balances = data?.data?.userBalances?.balances || [];
            const currency = getCurrency();
            const balance = balances.find(b => b.currency === currency);
            
            if (balance) {
                return balance.playableBalance.smallestUnits / 1000000;
            }
            return 0;
            
        } catch(e) {
            return 0;
        }
    }

