            else if (hour < 14) newProfile = 'distracted';
            else if (hour < 18) newProfile = 'excited';
            else if (hour < 21) newProfile = 'focused';
            else newProfile = 'tired';

            if (Math.random() < 0.1) {
                const moods = ['casual', 'focused', 'distracted', 'tired', 'excited'];
                const randomMood = moods[Math.floor(Math.random() * moods.length)];
                if (randomMood !== this.profile) newProfile = randomMood;
            }

            if (newProfile !== this.profile) {
                this.profile = newProfile;
                addLog('Mood: ' + newProfile, '#60a5fa', 'mood');
            }
        },

        async doRandomActivity() {
            const activities = [
                { name: 'check_phone', chance: 0.10, duration: () => 10000 + Math.random() * 20000, action: () => addLog('Check phone', '#888', 'phone') },
                { name: 'check_balance', chance: 0.08, duration: () => 3000 + Math.random() * 5000, action: () => { addLog('Check balance', '#888', 'balance'); updateUserInfo(); } },
                { name: 'check_time', chance: 0.05, duration: () => 2000 + Math.random() * 3000, action: () => addLog('Check time: ' + new Date().toLocaleTimeString(), '#888', 'time') },
                { name: 'scroll', chance: 0.08, duration: () => 5000 + Math.random() * 10000, action: () => addLog('Scroll', '#888', 'scroll') },
                { name: 'stretch', chance: 0.03, duration: () => 8000 + Math.random() * 12000, action: () => addLog('Stretch', '#888', 'stretch') },
                { name: 'distracted', chance: 0.06, duration: () => 10000 + Math.random() * 20000, action: () => addLog('Distracted', '#888', 'distracted') }
            ];

            const elapsed = Date.now() - this.sessionStart;
            const fatigue = Math.min(elapsed / 3600000, 3);
            const totalChance = activities.reduce((sum, a) => sum + a.chance, 0) * Math.min(fatigue, 2);

            if (Math.random() > totalChance) return;

            const available = activities.filter(a => Math.random() < a.chance);
            if (!available.length) return;

            const activity = available[Math.floor(Math.random() * available.length)];
            activity.action();
            await sleep(activity.duration());
            addLog('Back to focus', '#888', 'focus');
            await this.think('focused');
        },

        shouldDoActivity() {
            const elapsed = Date.now() - this.sessionStart;
            const fatigue = Math.min(elapsed / 3600000, 3);
            const chance = 0.10 * Math.min(fatigue, 2);
            return Math.random() < chance;
        }
    };

