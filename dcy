    // ============================================================
    // CLOSE SPLASH - KLIK LAYAR BEBAS
    // ============================================================
    function closeWinSplash() {
        try {
            const modals = document.querySelectorAll('[role="dialog"], .modal, [class*="modal"], [class*="splash"]');
            
            for (let modal of modals) {
                const isVisible = modal.offsetParent !== null || getComputedStyle(modal).display !== 'none';
                if (!isVisible) continue;
                
                const text = modal.textContent || '';
                if (!text.includes('YOU WON') && !text.includes('you won') && !text.includes('WON')) {
                    continue;
                }
                
                addLog('🏆 Splash detected, closing...', '#ffd700', '🏆');
                
                const rect = modal.getBoundingClientRect();
                const x = rect.left + (rect.width / 2);
                const y = rect.top + (rect.height * 0.05);
                
                const clickEvent = new MouseEvent('click', {
                    view: window,
                    bubbles: true,
                    cancelable: true,
                    clientX: x,
                    clientY: y
                });
                
                const elementAtPoint = document.elementFromPoint(x, y);
                
                if (elementAtPoint) {
                    elementAtPoint.dispatchEvent(clickEvent);
                    addLog('✅ Splash closed', '#4ade80', '✅');
                    return true;
                }
                
                modal.dispatchEvent(clickEvent);
                addLog('✅ Splash closed (fallback)', '#4ade80', '✅');
                return true;
            }
            
            return false;
            
        } catch(e) {
            addLog('⚠️ Close splash error: ' + e.message, '#ff922b', '⚠️');
            return false;
        }
    }

    // ============================================================
    // CHECK RAIN PAYOUT + CLOSE SPLASH (SATU PAKET!)
    // ============================================================
    async function checkRainPayoutAndClose() {
        try {
            const response = await fetch('https://api.dicey.com/graphql', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                credentials: 'include',
                body: JSON.stringify({
                    operationName: 'UserActivities',
                    query: `
                        query UserActivities($filters: UserActivityFilters, $first: Int) {
                            userActivities(filters: $filters, first: $first) {
                                edges {
                                    node {
                                        id
                                        type
                                        status
                                        time
                                        usdAmount
                                        amount {
                                            smallestUnits
                                            currencyCode
                                        }
                                    }
                                }
                            }
                        }
                    `,
                    variables: {
                        filters: { category: "REWARDS" },
                        first: 5
                    }
                })
            });
            
            const data = await response.json();
            const activities = data?.data?.userActivities?.edges || [];
            
            const now = Date.now();
            const fiveMinutesAgo = now - (5 * 60 * 1000);
            
            let foundPayout = false;
            
            for (let edge of activities) {
                const node = edge.node;
                if (node.type === 'RAIN_PAYOUT' && node.status === 'FINALIZED') {
                    const payoutTime = new Date(node.time).getTime();
                    if (payoutTime > fiveMinutesAgo) {
                        foundPayout = true;
                        const amount = parseFloat(node.usdAmount);
                        
                        addLog('🏆 YOU WON! +' + amount.toFixed(2) + ' USD', '#ffd700', '🏆');
                        updatePayoutUI({ win: true, usdAmount: amount, time: node.time });
                        
                        // 🔥 EKSEKUSI CLOSE SPLASH!
                        addLog('🔄 Closing splash...', '#60a5fa', '🔄');
                        
                        // Tunggu sebentar biar splash muncul
                        await sleep(1500);
                        
                        // Coba close sampai berhasil (max 10x)
                        let closed = false;
                        for (let i = 0; i < 10; i++) {
                            const result = closeWinSplash();
                            if (result) {
                                closed = true;
                                break;
                            }
                            await sleep(500);
                        }
                        
                        if (closed) {
                            addLog('✅ Splash closed!', '#4ade80', '✅');
                        } else {
                            addLog('⚠️ Splash not found or already closed', '#ff922b', '⚠️');
                        }
                        
                        return { win: true, amount };
                    }
                }
            }
            
            if (!foundPayout) {
                addLog('😢 No payout found', '#888', '😢');
                updatePayoutUI({ win: false });
            }
            
            return { win: false };
            
        } catch(e) {
            addLog('❌ Payout check error: ' + e.message, '#f87171', '❌');
            return { win: false, error: e.message };
        }
    }

