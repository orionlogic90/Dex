    async function fetchBalance() {
        try {
            const response = await fetch('https://api.dicey.com/graphql', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                credentials: 'include',
                body: JSON.stringify({
                    operationName: 'UserBalances',
                    query: `query UserBalances { userBalances { balances { currency playableBalance { smallestUnits currencyCode } } } }`
                })
            });
            const data = await response.json();
            const balances = data?.data?.userBalances?.balances || [];
            const currency = getCurrency();
            const balance = balances.find(b => b.currency === currency);
            if (balance) {
                return balance.playableBalance.smallestUnits / 1000000;
            }
            return 0;
        } catch (e) {
            return 0;
        }
    }

    async function placeBet(betAmount, chance) {
        const cryptoCurrency = getCurrency();
        const targetNumber = Math.floor((chance / 100) * 10000);
        const query = `mutation PlaceDiceBet($input: DiceBetInput!) { placeDiceBet(input: $input) { roundId activityId betAmount targetNumber targetNumberLower targetNumberUpper rollMode rolledNumber multiplier winAmount isWin profit timestamp } }`;
        const variables = {
            input: {
                betAmount: String(betAmount),
                cryptoCurrency: cryptoCurrency,
                nonce: generateUUID(),
                rollMode: 'Under',
                targetNumber: targetNumber
            }
        };
        try {
            const response = await fetch('https://api.dicey.com/graphql', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
                credentials: 'include',
                body: JSON.stringify({ operationName: 'PlaceDiceBet', query: query, variables: variables })
            });
            if (!response.ok) throw new Error('HTTP ' + response.status);
            const data = await response.json();
            if (data.errors) throw new Error(data.errors[0].message);
            return { success: true, data: data.data.placeDiceBet };
        } catch (error) {
            return { success: false, error: error.message };
        }
    }

