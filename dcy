    // ============================================================
    // UPDATE RAIN TIMER UI
    // ============================================================
    function updateRainTimer(rainData) {
        const nextEl = document.getElementById('dicey-rain-next');
        const endsEl = document.getElementById('dicey-rain-ends');
        const amountEl = document.getElementById('dicey-rain-amount');
        const participantsEl = document.getElementById('dicey-rain-participants');
        
        if (!rainData) {
            if (nextEl) nextEl.textContent = '⏳ Next: --';
            if (endsEl) endsEl.textContent = '⏰ Ends: --';
            if (amountEl) amountEl.textContent = '💰 --';
            if (participantsEl) participantsEl.textContent = '👥 --';
            return;
        }
        
        const now = new Date();
        const startsAt = new Date(rainData.startsAt);
        const settlesAt = new Date(rainData.settlesAt);
        const status = rainData.status;
        
        if (amountEl) amountEl.textContent = '💰 $' + parseFloat(rainData.totalUsdAmount || 0).toFixed(2);
        if (participantsEl) participantsEl.textContent = '👥 ' + (rainData.participantCount || 0);
        
        if (status === 'Settled' || now > settlesAt) {
            if (nextEl) nextEl.textContent = '⏳ Finished';
            if (endsEl) endsEl.textContent = '⏰ --';
            return;
        }
        
        if (now >= startsAt && now <= settlesAt) {
            const timeLeft = settlesAt.getTime() - now.getTime();
            const mins = String(Math.floor(timeLeft / 60000)).padStart(2, '0');
            const secs = String(Math.floor((timeLeft % 60000) / 1000)).padStart(2, '0');
            if (nextEl) nextEl.textContent = '🔥 Active';
            if (endsEl) endsEl.textContent = '⏰ Ends: ' + mins + ':' + secs;
        } else if (now < startsAt) {
            const timeUntil = startsAt.getTime() - now.getTime();
            const mins = String(Math.floor(timeUntil / 60000)).padStart(2, '0');
            const secs = String(Math.floor((timeUntil % 60000) / 1000)).padStart(2, '0');
            if (nextEl) nextEl.textContent = '⏳ Next: ' + mins + ':' + secs;
            if (endsEl) endsEl.textContent = '⏰ Starts: ' + startsAt.toLocaleTimeString();
        }
    }

    // ============================================================
    // START/STOP RAIN TIMER
    // ============================================================
    function startRainTimer() {
        if (rainState.timerInterval) {
            clearInterval(rainState.timerInterval);
        }
        
        rainState.timerInterval = setInterval(() => {
            fetchRainSchedule().then(rainData => {
                if (rainData) {
                    updateRainTimer(rainData);
                    const dot = document.getElementById('dicey-rain-dot');
                    const statusText = document.getElementById('dicey-rain-status');
                    if (dot && statusText) {
                        const now = new Date();
                        const startsAt = new Date(rainData.startsAt);
                        const settlesAt = new Date(rainData.settlesAt);
                        if (rainData.status === 'Active' && now >= startsAt && now <= settlesAt) {
                            dot.style.background = '#4ade80';
                            statusText.textContent = 'ACTIVE';
                            statusText.style.color = '#4ade80';
                        } else if (now < startsAt) {
                            dot.style.background = '#ff922b';
                            statusText.textContent = 'SCHEDULED';
                            statusText.style.color = '#ff922b';
                        } else {
                            dot.style.background = '#888';
                            statusText.textContent = 'IDLE';
                            statusText.style.color = '#888';
                        }
                    }
                }
            }).catch(() => {});
        }, 1000);
    }

    function stopRainTimer() {
        if (rainState.timerInterval) {
            clearInterval(rainState.timerInterval);
            rainState.timerInterval = null;
        }
        updateRainTimer(null);
    }

    // ============================================================
    // JOIN RAIN
    // ============================================================
    async function joinRainDirect(potId) {
        try {
            const response = await fetch('https://api.dicey.com/graphql', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                credentials: 'include',
                body: JSON.stringify({
                    operationName: 'JoinRain',
                    query: `
                        mutation JoinRain($potId: ID!) {
                            joinRain(potId: $potId) {
                                joined alreadyJoined ineligibleReason
                            }
                        }
                    `,
                    variables: { potId }
                })
            });
            return await response.json();
        } catch(e) {
            return { error: e.message };
        }
    }

    // ============================================================
    // HANDLE RAIN EVENT
    // ============================================================
    function handleRainEvent(rainData) {
        const potId = rainData.id;
        
        if (rainState.joinedRains.has(potId)) {
            return;
        }
        
        addLog('🌧️ Joining rain: $' + rainData.totalUsdAmount, '#ff922b', '🌧️');
        
        joinRainDirect(potId).then(result => {
            if (result?.data?.joinRain?.joined === true) {
                rainState.successCount++;
                rainState.joinedRains.add(potId);
                addLog('🌧️ ✅ Joined rain!', '#4ade80', '🌧️');
            } else {
                const reason = result?.data?.joinRain?.ineligibleReason || 'Unknown';
                rainState.failCount++;
                addLog('🌧️ ❌ Failed: ' + reason, '#f87171', '🌧️');
            }
            updateRainUI();
        });
    }

    // ============================================================
    // RAIN CYCLE (API LOOP - TANPA WEBSOCKET)
    // ============================================================
    function runRainCycle() {
        if (!rainState.isRunning) return;
        
        addLog('🌧️ Checking rain schedule...', '#60a5fa', '🌧️');
        
        // STEP 1: PASTIKAN DI /chat
        if (!window.location.href.includes('/chat')) {
            addLog('📍 Navigating to /chat...', '#60a5fa', '📍');
            window.location.href = 'https://dicey.com/chat';
            setTimeout(() => {
                if (rainState.isRunning) {
                    runRainCycle();
                }
            }, 3000);
            return;
        }
        
        // STEP 2: FISHING MOMENT (SEKALI)
        if (!fishingDone) {
            addLog('🎣 Fishing required: 0.51 ' + getCurrency() + ' @ 98%', '#ff922b', '🎣');
            doFishingMoment().then(() => {
                if (rainState.isRunning) {
                    executeRainCycle();
                }
            });
            return;
        }
        
        // STEP 3: EKSEKUSI RAIN CYCLE
        executeRainCycle();
    }

    function executeRainCycle() {
        if (!rainState.isRunning) return;
        
        // Start timer UI
        startRainTimer();
        startChatRefreshLoop();
        
        // LANGSUNG CEK RAIN SCHEDULE
        fetchRainSchedule().then(rainData => {
            if (rainData) {
                updateRainTimer(rainData);
                
                const now = new Date();
                const startsAt = new Date(rainData.startsAt);
                const settlesAt = new Date(rainData.settlesAt);
                const status = rainData.status;
                
                // 1. SUDAH SETTLED → CEK PAYOUT!
                if (status === 'Settled' || now > settlesAt) {
                    addLog('⏰ Rain settled! Checking payout...', '#888', '⏰');
                    checkRainPayoutAndClose();
                    // LANGSUNG CEK LAGI 5 MENIT
                    setTimeout(() => {
                        if (rainState.isRunning) {
                            runRainCycle();
                        }
                    }, 5 * 60 * 1000);
                    return;
                }
                
                // 2. RAIN AKTIF → JOIN + SCHEDULE CEK
                if (now >= startsAt && now <= settlesAt) {
                    addLog('🔥 Rain is active! $' + rainData.totalUsdAmount, '#ff922b', '🔥');
                    handleRainEvent(rainData);
                    
                    const timeToSettle = settlesAt.getTime() - now.getTime();
                    
                    // Schedule cek payout saat settle
                    setTimeout(() => {
                        addLog('🔔 Settle time! Checking payout...', '#ffd700', '🔔');
                        checkRainPayoutAndClose();
                        // LANGSUNG CEK LAGI 5 MENIT
                        setTimeout(() => {
                            if (rainState.isRunning) {
                                runRainCycle();
                            }
                        }, 5 * 60 * 1000);
                    }, timeToSettle + 5000);
                    return;
                }
                
                // 3. BELUM MULAI → TUNGGU SAMPAI startsAt
                if (now < startsAt) {
                    const timeUntilStart = startsAt.getTime() - now.getTime();
                    const minutesUntilStart = Math.floor(timeUntilStart / 60000);
                    addLog('⏳ Rain starts in ' + minutesUntilStart + ' minutes (at ' + startsAt.toLocaleTimeString() + ')', '#60a5fa', '⏳');
                    
                    setTimeout(() => {
                        if (rainState.isRunning) {
                            runRainCycle();
                        }
                    }, timeUntilStart + 5000);
                    return;
                }
                
            } else {
                // TIDAK ADA RAIN → CEK LAGI 5 MENIT
                addLog('⏳ No rain scheduled, checking again in 5 minutes...', '#888', '⏳');
                setTimeout(() => {
                    if (rainState.isRunning) {
                        runRainCycle();
                    }
                }, 5 * 60 * 1000);
            }
        });
    }

