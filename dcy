    function checkRainPayoutAPI(potId) {
        return fetch('https://api.dicey.com/graphql', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            credentials: 'include',
            body: JSON.stringify({
                operationName: 'UserActivities',
                query: 'query UserActivities($filters: UserActivityFilters, $first: Int) { userActivities(filters: $filters, first: $first) { edges { node { id type status time usdAmount metadata } } } }',
                variables: { filters: { category: "REWARDS" }, first: 10 }
            })
        }).then(function(response) {
            return response.json();
        }).then(function(data) {
            var activities = data?.data?.userActivities?.edges || [];
            var now = Date.now();
            var fiveMinutesAgo = now - (5 * 60 * 1000);
            for (var i = 0; i < activities.length; i++) {
                var node = activities[i].node;
                if (node.type === 'RAIN_PAYOUT' && node.status === 'FINALIZED') {
                    var payoutTime = new Date(node.time).getTime();
                    if (payoutTime > fiveMinutesAgo) {
                        return { found: true, amount: parseFloat(node.usdAmount) || 0, time: node.time };
                    }
                }
            }
            return { found: false };
        }).catch(function() {
            return { found: false };
        });
    }

