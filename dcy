    // ============================================================
    // RAIN LOOP (with human behavior)
    // ============================================================
    async function rainLoop() {
        if (!rainState.isRunning || rainState.stopRequested) return;

        try {
            // Human behavior: random activity check
            if (Human.shouldDoActivity()) {
                await Human.doRandomActivity();
            }

            // Check rain schedule
            const rainData = await fetchRainSchedule();

            if (!rainData) {
                // No rain scheduled
                const delay = CONFIG.RAIN.checkIntervalMin + Math.random() * (CONFIG.RAIN.checkIntervalMax - CONFIG.RAIN.checkIntervalMin);
                scheduleRainCheck(delay);
                return;
            }

            const now = new Date();
            const startsAt = new Date(rainData.startsAt);
            const settlesAt = new Date(rainData.settlesAt);
            const potId = rainData.id;

            // Update UI with rain info
            updateRainTimer(rainData);

            // Check if rain is active and not joined
            if (rainData.status === 'ACTIVE' && now >= startsAt && now <= settlesAt && !rainState.joinedRains.has(potId)) {
                const amount = parseFloat(rainData.totalUsdAmount) || 0;

                // Human-like evaluation: skip small rains sometimes
                let shouldJoin = true;
                if (amount < CONFIG.RAIN.skipSmallAmount) {
                    if (Math.random() < CONFIG.RAIN.skipRate) {
                        shouldJoin = false;
                        addLog('Skipping small rain: $' + amount.toFixed(2), '#888', 'rain');
                    }
                }

                // Human-like hesitation delay
                const delay = CONFIG.RAIN.joinDelayMin + Math.random() * (CONFIG.RAIN.joinDelayMax - CONFIG.RAIN.joinDelayMin);
                addLog('Rain active: $' + amount.toFixed(2) + ' (joining in ' + Math.floor(delay/1000) + 's)', '#ff922b', 'rain');
                await sleep(delay);

                if (shouldJoin && rainState.isRunning && !rainState.stopRequested) {
                    const result = await joinRainDirect(potId);

                    if (result?.data?.joinRain?.joined) {
                        rainState.joinedRains.add(potId);
                        rainState.successCount++;
                        addLog('Joined rain!', '#4ade80', 'rain');
                        updateRainUI();

                        // Schedule payout check
                        const timeToSettle = settlesAt.getTime() - Date.now();
                        setTimeout(async () => {
                            if (!rainState.isRunning || rainState.stopRequested) return;
                            addLog('Checking payout...', '#ffd700', 'rain');
                            const payout = await checkRainPayoutAPI(potId);
                            if (payout.found) {
                                rainState.wins++;
                                rainState.totalPayout += payout.amount;
                                addLog('WIN! +' + payout.amount.toFixed(2) + ' USD', '#4ade80', 'rain');
                                updatePayoutUI({ win: true, usdAmount: payout.amount, time: payout.time });
                            } else {
                                addLog('No payout for this rain', '#888', 'rain');
                                updatePayoutUI({ win: false });
                            }
                            updateRainUI();
                        }, timeToSettle + 2000);

                        // Schedule next check after rain settles
                        scheduleRainCheck(timeToSettle + 10000);
                        return;

                    } else {
                        const reason = result?.data?.joinRain?.ineligibleReason || 'Unknown';
                        rainState.failCount++;
                        addLog('Failed to join: ' + reason, '#f87171', 'rain');
                        updateRainUI();

                        // Handle insufficient wager
                        const wagerKeywords = ['Wager', 'wagered', 'Insufficient', 'Requirement'];
                        const isWagerIssue = wagerKeywords.some(k => reason.includes(k));
                        if (isWagerIssue) {
                            addLog('Insufficient wager detected, auto wager...', '#ff922b', 'rain');
                            const success = await doAutoWagerToTarget();
                            if (success) {
                                addLog('Wager target reached, retrying...', '#4ade80', 'rain');
                                scheduleRainCheck(3000 + Math.random() * 2000);
                            } else {
                                addLog('Failed to reach wager target', '#f87171', 'rain');
                                scheduleRainCheck(60000 + Math.random() * 30000);
                            }
                        } else {
                            scheduleRainCheck(30000 + Math.random() * 30000);
                        }
                        return;
                    }
                } else {
                    // Skipped or not joining
                    scheduleRainCheck(30000 + Math.random() * 30000);
                    return;
                }
            }

            // Rain not active yet or already settled
            if (now < startsAt) {
                const timeUntilStart = startsAt.getTime() - now.getTime();
                const minutes = Math.floor(timeUntilStart / 60000);
                addLog('Next rain in ' + minutes + ' minutes', '#60a5fa', 'rain');

                // Check more frequently as rain approaches
                const checkDelay = timeUntilStart > 120000 ?
                    Math.min(timeUntilStart + 5000, 120000) :
                    5000 + Math.random() * 10000;

                scheduleRainCheck(checkDelay);
            } else {
                // Rain settled, wait for next
                scheduleRainCheck(60000 + Math.random() * 60000);
            }

        } catch (e) {
            addLog('Rain error: ' + e.message, '#f87171', 'error');
            scheduleRainCheck(30000 + Math.random() * 30000);
        }
    }

    function scheduleRainCheck(delay) {
        if (rainState.checkTimeout) {
            clearTimeout(rainState.checkTimeout);
            rainState.checkTimeout = null;
        }
        if (!rainState.isRunning || rainState.stopRequested) return;
        rainState.checkTimeout = setTimeout(rainLoop, delay);
    }

    // ============================================================
    // AUTO WAGER FOR RAIN ELIGIBILITY
    // ============================================================
    async function doAutoWagerToTarget() {
        const target = CONFIG.FISHING.targetWager;
        const betAmount = 0.01;
        const chance = 98;
        const maxAttempts = 300;

        let currentWager = wagerState.wagered || 0;
        let attempts = 0;
        let successCount = 0;

        addLog('Auto wager started - Target: ' + target + ' ' + getCurrency(), '#60a5fa', 'auto');

        while (currentWager < target && attempts < maxAttempts && !rainState.stopRequested) {
            attempts++;
            const result = await placeBet(betAmount, chance);
            if (result.success) {
                successCount++;
                currentWager += betAmount;
                wagerState.wagered += betAmount;
                if (attempts % 10 === 0 || currentWager >= target) {
                    addLog('Wager progress: ' + currentWager.toFixed(4) + '/' + target + ' ' + getCurrency() + ' (' + (currentWager / target * 100).toFixed(1) + '%)', '#ffd700', 'auto');
                    updateWagerUI();
                }
            } else {
                addLog('Wager failed: ' + result.error, '#ff922b', 'auto');
            }
            await sleep(Human.getDelay(500));
        }

        addLog('Auto wager completed: ' + successCount + ' success, ' + (attempts - successCount) + ' failed', '#60a5fa', 'auto');
        return currentWager >= target;
    }

    // ============================================================
    // RAIN CONTROL FUNCTIONS
    // ============================================================
    function startRainCatcher() {
        if (!isLicensed) {
            addLog('License required for rain catcher', '#f87171', 'error');
            return;
        }
        if (rainState.isRunning) {
            addLog('Already running', '#ffd700', 'info');
            return;
        }

        rainState.isRunning = true;
        rainState.stopRequested = false;
        rainState.joinedRains = new Set();
        rainState.successCount = 0;
        rainState.failCount = 0;
        rainState.wins = 0;
        rainState.totalPayout = 0;

        addLog('Rain catcher started', '#4ade80', 'rain');
        updateRainUI();

        // Start fishing session (background, non-blocking)
        if (!fishingState.done && !fishingState.isRunning) {
            addLog('Starting fishing session (30 minutes)', '#ff922b', 'fish');
            startFishingSession(); // Don't await - runs in background
        }

        // Start rain loop (main, non-blocking)
        setTimeout(rainLoop, Human.getDelay(1000));
    }

    function stopRainCatcher() {
        rainState.isRunning = false;
        rainState.stopRequested = true;
        if (rainState.checkTimeout) {
            clearTimeout(rainState.checkTimeout);
            rainState.checkTimeout = null;
        }
        if (rainState.timerInterval) {
            clearInterval(rainState.timerInterval);
            rainState.timerInterval = null;
        }
        fishingState.stopRequested = true;
        fishingState.isRunning = false;
        addLog('Rain catcher stopped', '#f87171', 'rain');
        updateRainUI();
        updateFishingUI(fishingState.done, fishingState.done ? 'Done' : 'Stopped');
    }

