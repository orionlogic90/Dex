        getDelay(baseMs, profileOverride) {
            const p = profileOverride || this.profile;
            const profiles = {
                casual: { jitter: 0.5, hesitate: 0.15, extra: 800 },
                focused: { jitter: 0.3, hesitate: 0.05, extra: 400 },
                distracted: { jitter: 0.7, hesitate: 0.25, extra: 1200 },
                tired: { jitter: 0.6, hesitate: 0.30, extra: 1500 },
                excited: { jitter: 0.2, hesitate: 0.02, extra: 200 }
            };
            const data = profiles[p] || profiles.casual;

            let delay = baseMs * (1 + (Math.random() * 2 - 1) * data.jitter);
            if (Math.random() < data.hesitate) {
                delay += data.extra * Math.random();
            }

            const elapsed = Date.now() - this.lastAction;
            if (elapsed > 300000) delay *= 1.2;
            if (this.activityCount > 50) {
                delay *= 1 + (this.activityCount - 50) * 0.001;
            }

            this.activityCount++;
            this.lastAction = Date.now();
            return Math.max(50, Math.min(delay, 5000));
        },

        async think(profile) {
            const delay = this.getDelay(200, profile);
            return new Promise(r => setTimeout(r, delay));
        },

        async quickRespond() {
            const delay = this.getDelay(50, 'excited');
            return new Promise(r => setTimeout(r, delay));
