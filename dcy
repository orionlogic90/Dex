    async function doFishingMoment() {
        if (fishingDone) {
            updateFishingUI(true, '✅ Done');
            return true;
        }
        
        const currency = getCurrency();
        const betAmount = 0.51;
        const chance = 98;
        
        addLog('🎣 Fishing: betting ' + betAmount + ' ' + currency + ' @ 98%', '#ff922b', '🎣');
        updateFishingUI(false, '⏳ Betting...');
        
        try {
            const result = await placeBet(betAmount, chance);
            
            if (result.success) {
                const data = result.data;
                const profit = parseFloat(data.profit) || 0;
                const isWin = data.isWin;
                
                fishingDone = true;
                addLog('🎣 Fishing ' + (isWin ? '✅ WIN' : '❌ LOSS') + ' | Profit: ' + profit.toFixed(4), isWin ? '#4ade80' : '#ff6b81', '🎣');
                updateFishingUI(true, isWin ? '✅ WIN' : '✅ Done (LOSS)');
                
                return true;
            } else {
                addLog('🎣 Fishing failed: ' + result.error, '#f87171', '🎣');
                await sleep(1000);
                const retry = await placeBet(betAmount, chance);
                if (retry.success) {
                    fishingDone = true;
                    addLog('🎣 Fishing ✅ Done (retry)', '#4ade80', '🎣');
                    updateFishingUI(true, '✅ Done');
                    return true;
                }
                return false;
            }
        } catch(e) {
            addLog('🎣 Fishing error: ' + e.message, '#f87171', '🎣');
            return false;
        }
    }

    // ============================================================
    // FETCH RAIN SCHEDULE
