    // ============================================================
    // EVENT BINDING
    // ============================================================
    function bindEvents() {
        // License
        $('dicey-check-license')?.addEventListener('click', updateLicenseStatus);
        $('dicey-license')?.addEventListener('keydown', e => { if (e.key === 'Enter') updateLicenseStatus(); });
        $('dicey-username')?.addEventListener('keydown', e => { if (e.key === 'Enter') updateLicenseStatus(); });

        // Wager
        $('dicey-wager-start')?.addEventListener('click', startWagerBot);
        $('dicey-wager-pause')?.addEventListener('click', pauseWagerBot);
        $('dicey-wager-stop')?.addEventListener('click', stopWagerBot);
        $('dicey-wager-reset')?.addEventListener('click', resetWagerBot);

        // Rain
        $('dicey-rain-start')?.addEventListener('click', startRainCatcher);
        $('dicey-rain-stop')?.addEventListener('click', stopRainCatcher);

        // Currency change
        $('dicey-currency')?.addEventListener('change', () => {
            updateWagerUI();
            updateFishingUI(fishingState.done, fishingState.done ? 'Done' : 'Pending');
        });

        // Log clear
        $('dicey-log-clear')?.addEventListener('click', () => {
            const log = $('dicey-log');
            if (log) { log.innerHTML = ''; addLog('Log cleared', '#888', 'clear'); }
        });

        // Minimize/Close
        let minimized = false;
        $('dicey-minimize')?.addEventListener('click', function() {
            minimized = !minimized;
            const content = $('dicey-content');
            if (content) content.style.display = minimized ? 'none' : 'block';
            this.textContent = minimized ? '+' : '-';
            const container = document.getElementById('dicey-bot-ui');
            if (container) container.style.height = minimized ? '44px' : '100%';
        });

        $('dicey-close')?.addEventListener('click', function() {
            if (wagerState.isRunning) stopWagerBot();
            if (rainState.isRunning) stopRainCatcher();
            const container = document.getElementById('dicey-bot-ui');
            if (container) container.style.display = 'none';
        });

        // Tab switching
        const tabs = document.querySelectorAll('.dicey-tab');
        tabs.forEach(btn => {
            btn.addEventListener('click', function() {
                const tabId = this.dataset.tab;
                const contents = {
                    main: document.getElementById('tab-main'),
                    cfg: document.getElementById('tab-cfg')
                };
                Object.keys(contents).forEach(key => {
                    if (contents[key]) contents[key].style.display = 'none';
                });
                if (contents[tabId]) contents[tabId].style.display = 'block';
                tabs.forEach(b => {
                    const isActive = b.dataset.tab === tabId;
                    b.style.color = isActive ? '#9ec07c' : '#a0a0a0';
                    b.style.borderBottomColor = isActive ? '#9ec07c' : 'transparent';
                });
            });
        });

        // Keyboard shortcuts
        document.addEventListener('keydown', function(e) {
            if (e.ctrlKey && e.shiftKey && e.key === 'D') {
                e.preventDefault();
                const container = document.getElementById('dicey-bot-ui');
                if (container) container.style.display = container.style.display === 'none' ? 'block' : 'none';
            }
            if (e.key === 'Enter' && e.ctrlKey) {
                e.preventDefault();
                if (wagerState.isRunning) stopWagerBot();
                else startWagerBot();
            }
            if (e.key === ' ' && e.ctrlKey) {
                e.preventDefault();
                pauseWagerBot();
            }
        });

        // Draggable
        const header = document.getElementById('dicey-header');
        const container = document.getElementById('dicey-bot-ui');
        let isDragging = false;
        let dragOffsetX, dragOffsetY;

        header?.addEventListener('mousedown', function(e) {
            if (e.target.closest('button')) return;
            isDragging = true;
            const rect = container.getBoundingClientRect();
            dragOffsetX = e.clientX - rect.left;
            dragOffsetY = e.clientY - rect.top;
            container.style.cursor = 'grabbing';
            e.preventDefault();
        });

        document.addEventListener('mousemove', function(e) {
            if (!isDragging) return;
            let x = e.clientX - dragOffsetX;
            let y = e.clientY - dragOffsetY;
            x = Math.max(0, Math.min(window.innerWidth - container.offsetWidth, x));
            y = Math.max(0, Math.min(window.innerHeight - container.offsetHeight, y));
            container.style.left = x + 'px';
            container.style.right = 'auto';
            container.style.bottom = 'auto';
            container.style.top = y + 'px';
        });

        document.addEventListener('mouseup', function() {
            isDragging = false;
            container.style.cursor = '';
        });
    }

